<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:ui="http://v8.1c.ru/8.1/data/ui"
           xmlns:v81="http://v8.1c.ru/8.1/data/core"
           xmlns:ent="http://v8.1c.ru/8.1/data/enterprise"
           xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform"
           xmlns:lfl="http://v8.1c.ru/8.2/managed-application/logform/layouter"
           targetNamespace="http://v8.1c.ru/8.3/managed-application/logform/hippo"
           xmlns:tns="http://v8.1c.ru/8.3/managed-application/logform/hippo"
           xmlns:spreadsheet="http://v8.1c.ru/8.2/data/spreadsheet"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">

    <xs:import namespace="http://v8.1c.ru/8.1/data/core" schemaLocation="../../../xdto/src/res/core.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/ui" schemaLocation="../../../xdto/src/res/uiobjects.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/logform" schemaLocation="logform.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/logform/layouter" schemaLocation="logformlay.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/spreadsheet" schemaLocation="../../../moxel/src/res/spreadsheetDocument.xsd"/>

  <!-- Порядок и количество элементов должны в точности соответсвовать:
         перечислению HLCategory в mngcore/IHippoLayouter.h
         перечислению Lay.HLCategory в mngsrv/src/res/js/multi/lay/hippolayouterenums.js -->
    <xs:simpleType name="ControlCategory">
        <!-- В языке нет -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="Main" />
            <xs:enumeration value="Title" />
            <xs:enumeration value="AlignedTitle" />
            <xs:enumeration value="ExtTooltip" />
            <xs:enumeration value="CloseBtnImage" />
            <xs:enumeration value="ShowData" />
            <xs:enumeration value="WidthDependedHeight" />
            <xs:enumeration value="ChangeHeightOnChangeData" />
            <xs:enumeration value="HorStretchPriority" />
            <xs:enumeration value="HorCompressPriority" />
            <xs:enumeration value="VerCompressPriority" />
            <xs:enumeration value="Spacing" />
            <xs:enumeration value="NoCalcHorContent" />
            <xs:enumeration value="NoCalcVerContent" />
            <xs:enumeration value="AlwaysVerticalAlign" />
            <xs:enumeration value="Align" />
            <xs:enumeration value="Primary" />
            <xs:enumeration value="AutoChangeVAlign" />
            <xs:enumeration value="AutoChangeRowsCount" />
            <xs:enumeration value="ContentStretchableMode" />
            <xs:enumeration value="ContentIndepended" />
            <xs:enumeration value="BehaviorIcon" />
            <xs:enumeration value="MasterColumn" />
            <xs:enumeration value="SlaveColumn" />
            <xs:enumeration value="HasSingleElement" />
            <xs:enumeration value="Layered" />
            <xs:enumeration value="LinkToAnchor" />
            <xs:enumeration value="FullScreen" />
            <xs:enumeration value="Anchor" />
            <xs:enumeration value="Sticky" />
            <xs:enumeration value="Splitter" />
            <xs:enumeration value="SlaveChangeVAlign" />
            <xs:enumeration value="NoHorStretchable" />
            <xs:enumeration value="NoVerStretchable" />
            <xs:enumeration value="SlaveVisibility" />
            <xs:enumeration value="AmpersandIsData" />
            <xs:enumeration value="PostGeneratorSizesInDLU" />
            <xs:enumeration value="MobileLeftCaption" />
            <xs:enumeration value="MobileRightCaption" />
            <xs:enumeration value="MobileAutoCloseButton" />
            <xs:enumeration value="MobileSpecialRightAlign" />
            <xs:enumeration value="MobileNoMobileTransformation" />
            <xs:enumeration value="MobileSeparatedColumn" />
            <xs:enumeration value="MobileSkippedColumns" />
            <xs:enumeration value="MobileTableGroupData" />
            <xs:enumeration value="ContainMobileSeparatedColumns" />
            <xs:enumeration value="MarkRequired" />
            <xs:enumeration value="CheckboxOrRadioButtonLabel" />
            <xs:enumeration value="SelectedItemsActionsPanelGroup" />
            <xs:enumeration value="SelectedItemsActionsPanelInGridGroup" />
            <xs:enumeration value="SelectedItemsActionsPanelInMoxelGroup" />
            <xs:enumeration value="SelectedItemsActionsPanelButton" />
            <xs:enumeration value="SelectedItemsActionsPanelLabelButton" />
            <xs:enumeration value="SelectedItemsActionsPanelCommandBar" />
            <xs:enumeration value="SelectedItemsActionsPanelInGridCommandBar" />
            <xs:enumeration value="SelectedItemsActionsPanelInMoxelCommandBar" />
            <xs:enumeration value="RowActionsPanelGroup" />
            <xs:enumeration value="RowActionsPanelCommandBar" />
            <xs:enumeration value="HierarchyPanelMenuGroup" />
            <xs:enumeration value="CollapsibleGroupTitle" />
            <xs:enumeration value="GroupTitle" />
            <xs:enumeration value="TopCommandBar" />
            <xs:enumeration value="SearchControl" />
            <xs:enumeration value="BottomCommandBar" />
            <xs:enumeration value="CreateButton" />
            <xs:enumeration value="FABCommandBar" />
            <xs:enumeration value="CollapsibleGroupCollapseButton" />
            <xs:enumeration value="EditInCommandBar" />
            <xs:enumeration value="CommandBarInGrid" />
        </xs:restriction>
    </xs:simpleType>
  
    <xs:complexType name="CategoryHolder">
        <xs:sequence>
            <xs:element name="item" type="tns:ControlCategory" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="HLEdge">
    <!-- В языке нет -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="Left" />
            <xs:enumeration value="Top" />
            <xs:enumeration value="Right" />
            <xs:enumeration value="Bottom" />
            <xs:enumeration value="None" />
            <xs:enumeration value="Auto" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="HLMenuElementRepresentation">
        <!-- В языке нет -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="Text" />
            <xs:enumeration value="Picture" />
            <xs:enumeration value="TextPicture" />
        </xs:restriction>
    </xs:simpleType>
  
    <xs:simpleType name="LogicGroupInternalRepresentation">
        <!-- В языке нет -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="None" />
            <xs:enumeration value="NoneBigTitle" />
            <xs:enumeration value="GroupBox" />
            <xs:enumeration value="Line" />
            <xs:enumeration value="Margin" />
            <xs:enumeration value="LeftLine" />
            <xs:enumeration value="MobileMargin" />
            <xs:enumeration value="MobileMarginLeftLine" />
        </xs:restriction>
    </xs:simpleType>
  
    <xs:simpleType name="LogicGroupRole">
        <!-- В языке нет -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="NoSpecialRole" />
            <xs:enumeration value="HyperlinkButtonGroupRole" />
            <xs:enumeration value="TableGroupRole" />
            <xs:enumeration value="MobileTitleAreaRole" />
            <xs:enumeration value="PageContentRole" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="ChoiceObjects">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Items" />
            <xs:enumeration value="Folders" />
            <xs:enumeration value="FoldersAndItems" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="SplitDirection">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Hor" />
            <xs:enumeration value="Ver" />
        </xs:restriction>
    </xs:simpleType>
    
    <xs:simpleType name="SplitMode">
        <xs:restriction base="xs:string">
            <xs:enumeration value="Move" />
            <xs:enumeration value="Scale" />
        </xs:restriction>
    </xs:simpleType>
    
    <xs:simpleType name="CBLocation">
        <xs:restriction base="xs:string">
            <xs:enumeration value="InForm" />
            <xs:enumeration value="FormTop" />
            <xs:enumeration value="FormBottom" />
            <xs:enumeration value="LeftCaption" />
            <xs:enumeration value="RightCaption" />
            <xs:enumeration value="InGrid" />
            <xs:enumeration value="FormFloat" />
        </xs:restriction>
    </xs:simpleType>

  <xs:simpleType name="GBBehavior">
    <xs:restriction base="xs:string">
      <xs:enumeration value="Usual" />
      <xs:enumeration value="Collapsible" />
      <xs:enumeration value="PopUp" />
      <xs:enumeration value="Auto" />
    </xs:restriction>
  </xs:simpleType>

    <xs:simpleType name="SeparatePanelAppearance">
      <xs:restriction base="xs:string">
        <xs:enumeration value="None" />
        <xs:enumeration value="PopUp" />
        <xs:enumeration value="ExtTooltip" />
        <xs:enumeration value="SelectedItemsActionsPanel" />
        <xs:enumeration value="RowActionsPanel" />
        <xs:enumeration value="FABPanel" />
      </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="SeparatePanelRole">
      <xs:restriction base="xs:string">
        <xs:enumeration value="NoSpecialRole" />
        <xs:enumeration value="PageRole" />
      </xs:restriction>
    </xs:simpleType>
      
    <!-- Список строк -->
    <xs:complexType name="Strings" >
        <xs:sequence>
            <xs:element name="item" type="xs:string" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>

    <!-- Список double -->
    <xs:complexType name="Doubles">
        <xs:sequence>
            <xs:element name="item" type="xs:double" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>

    <!-- Список картинок -->
    <xs:complexType name="Pictures">
      <xs:sequence>
        <xs:element name="item" type="ui:Picture" minOccurs="0" maxOccurs="unbounded" />
      </xs:sequence>
    </xs:complexType>

    <!-- Элемент тумблера -->
    <xs:complexType name="TumblerItem">
      <xs:sequence>
        <xs:element name="pic" type="ui:Picture" />
      </xs:sequence>
      <xs:attribute name="title" type="xs:string" />
    </xs:complexType>

    <!-- Список элементов тумблера -->
    <xs:complexType name="TumblerItems" >
      <xs:sequence>
        <xs:element name="item" type="tns:TumblerItem" minOccurs="0" maxOccurs="unbounded" />
      </xs:sequence>
    </xs:complexType>

    <!-- Базовый тип для элементов -->
    <xs:complexType name="Element" abstract="true" />

    <!-- Изменение элемента лайаутера -->
    <xs:complexType name="Item">
        <xs:sequence>
            <!-- Имя элемента-родителя, nil - нет родителя -->
            <xs:element name="parent" type="xs:string" nillable="true" minOccurs="0" />
            <xs:element name="elem" type="tns:Element" minOccurs="0 "/>
        </xs:sequence>
        <xs:attribute name="name" type="xs:string" use="required" />
        <xs:attribute name="create" type="xs:boolean" />
        <xs:attribute name="remove" type="xs:boolean" />
        <xs:attribute name="index" type="xs:decimal" />
    </xs:complexType>

    <!-- Список всех изменений лайаутера -->
    <xs:complexType name="Delta">
        <xs:sequence>
            <xs:element name="item" type="tns:Item" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
        <!-- Это полная дельта? По умолчанию - false -->
        <xs:attribute name="full" type="xs:boolean" />
    </xs:complexType>
    
    <!-- Группа свойств для интерфейса IHippoLayElement -->
    <xs:complexType name="LayElement">
        <xs:sequence>
            <!-- m_title по умолчанию пустой -->
            <xs:element name="title" type="xs:string" minOccurs="0" />
            <xs:element name="cats" type="tns:CategoryHolder" minOccurs="0" />
        </xs:sequence>
        <!-- m_logFormElementName по умолчанию == m_name-->
        <xs:attribute name="formItem" type="xs:string" />
        <!-- m_visible по умолчанию true-->
        <xs:attribute name="visible" type="xs:boolean" />
        <!-- m_groupVisible по умолчанию true-->
        <xs:attribute name="groupVisible" type="xs:boolean" />
        <!-- m_enabled по умолчанию true -->
        <xs:attribute name="enabled" type="xs:boolean" />
        <!-- m_groupEnabled по умолчанию true -->
        <xs:attribute name="groupEnabled" type="xs:boolean" />
        <!-- m_readOnly по умолчанию false -->
        <xs:attribute name="readOnly" type="xs:boolean" />
        <!-- m_groupReadOnly по умолчанию false -->
        <xs:attribute name="groupReadOnly" type="xs:boolean" />
        <!-- m_skipOnInput по умолчанию false -->
        <xs:attribute name="skip" type="xs:boolean" />
        <!-- m_defaultControl по умолчанию false -->
        <xs:attribute name="def" type="xs:boolean" />
        <!-- m_postGeneratorCrdsInDLU по умолчанию false -->
        <xs:attribute name="pgc" type="xs:boolean" />
    </xs:complexType>

    <!-- Группа свойств для интерфейса IHippoLayFormElement -->
    <xs:complexType name="LayFormElement">
        <!-- m_width по умолчанию 0 -->
        <xs:attribute name="width" type="xs:decimal" />
        <!-- m_minWidth по умолчанию 0 -->
        <xs:attribute name="minWidth" type="xs:decimal" />
        <!-- m_maxWidth по умолчанию 0 -->
        <xs:attribute name="maxWidth" type="xs:decimal" />
        <!-- m_height по умолчанию 0 -->
        <xs:attribute name="height" type="xs:decimal" />
        <!-- m_minHeight по умолчанию 0 -->
        <xs:attribute name="minHeight" type="xs:decimal" />
        <!-- m_maxHeight по умолчанию 0 -->
        <xs:attribute name="maxHeight" type="xs:decimal" />
        <!-- m_stretchableMode по умолчанию eNoStretchable -->
        <xs:attribute name="stretch" type="lfl:StretchableMode" />
        <!-- m_gridLeftPadding по умолчанию 0 -->
        <xs:attribute name="leftPadding" type="xs:decimal" />
        <!-- m_gridTopPadding по умолчанию 0 -->
        <xs:attribute name="topPadding" type="xs:decimal" />
        <!-- m_gridRightPadding по умолчанию 0 -->
        <xs:attribute name="rightPadding" type="xs:decimal" />
        <!-- m_gridBottomPadding по умолчанию 0 -->
        <xs:attribute name="bottomPadding" type="xs:decimal" />
        <!-- m_gridLeft по умолчанию 0 -->
        <xs:attribute name="gridLeft" type="xs:decimal" />
        <!-- m_gridTop по умолчанию 0 -->
        <xs:attribute name="gridTop" type="xs:decimal" />
        <!-- m_gridWidth по умолчанию 0 -->
        <xs:attribute name="gridWidth" type="xs:decimal" />
        <!-- m_gridHeight по умолчанию 0 -->
        <xs:attribute name="gridHeight" type="xs:decimal" />
        <!-- m_gridHAlign по умолчанию eHAAuto -->
        <xs:attribute name="gridHAlign" type="lf:ItemHorizontalAlignment" />
        <!-- m_gridVAlign по умолчанию eLFVAAuto -->
        <xs:attribute name="gridVAlign" type="lf:ItemVerticalAlignment" />
        <!-- m_alignedAreaTopOffset по умолчанию 0 -->
        <xs:attribute name="alignedAreaTopOffset" type="xs:decimal" />
        <!-- m_anchorName по умолчанию пустое -->
        <xs:attribute name="anchorName" type="xs:string" />
        <!-- m_layerNumber по умолчанию 0 -->
        <xs:attribute name="layerNumber" type="xs:decimal" />
        <!-- m_additionalAnchorName по умолчанию пустое -->
        <xs:attribute name="additionalAnchorName" type="xs:string" />
    </xs:complexType>

    <!-- Группа свойств для интерфейса IHippoLayFormElementExt -->
    <xs:complexType name="LayFormElementExt">
        <!-- m_minWidthWithCompressPriority по умолчанию 0 -->
        <xs:attribute name="minWidthWithCompressPriority" type="xs:decimal" />
        <!-- m_minWidthWithNormalPriority по умолчанию 0 -->
        <xs:attribute name="minWidthWithNormalPriority" type="xs:decimal" />
        <!-- m_minWidthWithStretchPriority по умолчанию 0 -->
        <xs:attribute name="minWidthWithStretchPriority" type="xs:decimal" />
        <!-- m_maxWidthWithStretchPriority по умолчанию 0 -->
        <xs:attribute name="maxWidthWithStretchPriority" type="xs:decimal" />
        <!-- m_maxWidthWithNormalPriority по умолчанию 0 -->
        <xs:attribute name="maxWidthWithNormalPriority" type="xs:decimal" />
        <!-- m_maxWidthWithCompressPriority по умолчанию 0 -->
        <xs:attribute name="maxWidthWithCompressPriority" type="xs:decimal" />
        <!-- m_narrowStandardWidth по умолчанию 0 -->
        <xs:attribute name="narrowStandardWidth" type="xs:decimal" />
        <!-- m_wideStandardWidth по умолчанию 0 -->
        <xs:attribute name="wideStandardWidth" type="xs:decimal" />
        <!-- m_standardWidth по умолчанию 0 -->
        <xs:attribute name="standardWidth" type="xs:decimal" />
        <!-- m_minHeightWithCompressPriority по умолчанию 0 -->
        <xs:attribute name="minHeightWithCompressPriority" type="xs:decimal" />
        <!-- m_minHeightWithNormalPriority по умолчанию 0 -->
        <xs:attribute name="minHeightWithNormalPriority" type="xs:decimal" />
        <!-- m_minHeightWithStretchPriority по умолчанию 0 -->
        <xs:attribute name="minHeightWithStretchPriority" type="xs:decimal" />
        <!-- m_maxHeightWithStretchPriority по умолчанию 0 -->
        <xs:attribute name="maxHeightWithStretchPriority" type="xs:decimal" />
        <!-- m_maxHeightWithNormalPriority по умолчанию 0 -->
        <xs:attribute name="maxHeightWithNormalPriority" type="xs:decimal" />
        <!-- m_maxHeightWithCompressPriority по умолчанию 0 -->
        <xs:attribute name="maxHeightWithCompressPriority" type="xs:decimal" />
        <!-- m_narrowStandardHeight по умолчанию 0 -->
        <xs:attribute name="narrowStandardHeight" type="xs:decimal" />
        <!-- m_wideStandardHeight по умолчанию 0 -->
        <xs:attribute name="wideStandardHeight" type="xs:decimal" />
        <!-- m_standardHeight по умолчанию 0 -->
        <xs:attribute name="standardHeight" type="xs:decimal" />
    </xs:complexType>

    <!-- Группа свойств для интерфейса IHippoLayElementWCM -->
    <xs:complexType name="LayElementWCM">
        <xs:sequence>
            <xs:element name="cm" type="xs:string" nillable="true" minOccurs="0" />
        </xs:sequence>
    </xs:complexType>

    <!-- Группа свойств для интерфейса IHippoLayElementWSIAP -->
    <xs:complexType name="LayElementWSIAP">
        <xs:sequence>
            <xs:element name="name" type="xs:string" nillable="true" minOccurs="0" />
        </xs:sequence>
    </xs:complexType>
  
    <!-- Элемент вируальной сетки -->
    <xs:complexType name="VGridItem">
        <xs:sequence>
            <!-- categoriesHolder -->
            <xs:element name="cats" type="tns:CategoryHolder" minOccurs="0" />
        </xs:sequence>
        <!-- length по умолчанию 0 -->
        <xs:attribute name="len" type="xs:decimal" />
        <!-- minLengthWithCompressPriority по умолчанию 0 -->
        <xs:attribute name="minLengthWithCompressPriority" type="xs:decimal" />
        <!-- minLengthWithNormalPriority по умолчанию 0 -->
        <xs:attribute name="minLengthWithNormalPriority" type="xs:decimal" />
        <!-- minLengthWithStretchPriority по умолчанию 0 -->
        <xs:attribute name="minLengthWithStretchPriority" type="xs:decimal" />
        <!-- maxLengthWithStretchPriority по умолчанию 0 -->
        <xs:attribute name="maxLengthWithStretchPriority" type="xs:decimal" />
        <!-- maxLengthWithNormalPriority по умолчанию 0 -->
        <xs:attribute name="maxLengthWithNormalPriority" type="xs:decimal" />
        <!-- maxLengthWithCompressPriority по умолчанию 0 -->
        <xs:attribute name="maxLengthWithCompressPriority" type="xs:decimal" />
        <!-- narrowStandardLength по умолчанию 0 -->
        <xs:attribute name="narrowStandardLength" type="xs:decimal" />
        <!-- wideStandardLength по умолчанию 0 -->
        <xs:attribute name="wideStandardLength" type="xs:decimal" />
        <!-- standardLength по умолчанию 0 -->
        <xs:attribute name="standardLength" type="xs:decimal" />
        <!-- slavePadding по умолчанию 0 -->
        <xs:attribute name="slavePadding" type="xs:decimal" />
        <!-- additionalData по умолчанию пустая -->
        <xs:attribute name="ad" type="xs:string" />
    </xs:complexType>

    <!-- Описание виртуальной сетки -->
    <xs:complexType name="VirtualGridDescr">
        <xs:sequence>
            <xs:element name="column" type="tns:VGridItem" minOccurs="0" maxOccurs="unbounded" />
            <xs:element name="row" type="tns:VGridItem" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
        <!-- m_childrenGridHAlign по умолчанию eHAAuto -->
        <xs:attribute name="childrenGridHAlign" type="lf:ItemHorizontalAlignment" />
        <!-- m_childrenGridVAlign по умолчанию eLFVAAuto -->
        <xs:attribute name="childrenGridVAlign" type="lf:ItemVerticalAlignment" />
    </xs:complexType>

    <!-- Группа свойств для интерфейса IHippoLayFormGroup -->
    <xs:complexType name="LayFormGroup">
        <!-- m_grouping по умолчанию eLFCGVertical -->
        <xs:attribute name="grouping" type="lf:FormChildrenGroup" />
        <!-- m_horizontalSpacing по умолчанию eLFESSingle -->
        <xs:attribute name="horizontalSpacing" type="lf:FormItemSpacing" />
        <!-- m_verticalSpacing по умолчанию eLFESSingle -->
        <xs:attribute name="verticalSpacing" type="lf:FormItemSpacing" />
        <!-- m_hAlign по умолчанию eHALeft -->
        <xs:attribute name="hAlign" type="lf:ItemHorizontalAlignment" />
        <!-- m_vAlign по умолчанию eLFVATop -->
        <xs:attribute name="vAlign" type="lf:ItemVerticalAlignment" />
        <!-- m_childrenAlign по умолчанию eLFCATitlesLeftDataLeft -->
        <xs:attribute name="align" type="lf:FormChildrenAlign" />
    </xs:complexType>

    <!-- Группа свойств для элемента Форма (IHippoLayForm) -->
    <xs:complexType name="Form">
        <xs:complexContent>
            <xs:extension base="tns:Element">
                <xs:sequence>
                    <xs:element name="e" type="tns:LayElement" minOccurs="0" />
                    <xs:element name="fg" type="tns:LayFormGroup" minOccurs="0" />
                    <xs:element name="vg" type="tns:VirtualGrid" minOccurs="0" />
                </xs:sequence>
                <!-- m_width по умолчанию 0 -->
                <xs:attribute name="width" type="xs:decimal" />
                <!-- m_height по умолчанию 0 -->
                <xs:attribute name="height" type="xs:decimal" />
                <!-- m_resWidth по умолчанию 0 -->
                <xs:attribute name="resWidth" type="xs:decimal" />
                <!-- m_resHeight по умолчанию 0 -->
                <xs:attribute name="resHeight" type="xs:decimal" />
                <!-- m_enterKeyBehavior по умолчанию eEBB_ControlNavigation -->
                <xs:attribute name="enter" type="lfl:FormEnterKeyBehavior" />
                <!-- m_verticalScrolling по умолчанию eLFSMUseIfNecessary -->
                <xs:attribute name="verScroll" type="lf:LogFormScrollMode" />
                <!-- m_showECSButton по умолчанию eLFSECShow -->
                <xs:attribute name="convRepr" type="lf:LogFormShowConversations" />
                <!-- m_childrenTitleLocation по умолчанию Auto -->
                <xs:attribute name="childrenTitleLocation" type="lf:ChildrenTitleLocation" />
                <!-- m_scaleVariant по умолчанию Auto -->
                <xs:attribute name="scaleVariant" type="ent:ClientApplicationFormScaleVariant" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <!-- Группа свойств для элемента Static Text (IHippoLayStaticText) -->
    <xs:complexType name="Label">
        <xs:complexContent>
            <xs:extension base="tns:Element">
                <xs:sequence>
                    <xs:element name="e" type="tns:LayElement" minOccurs="0" />
                    <xs:element name="fe" type="tns:LayFormElement" minOccurs="0" />
