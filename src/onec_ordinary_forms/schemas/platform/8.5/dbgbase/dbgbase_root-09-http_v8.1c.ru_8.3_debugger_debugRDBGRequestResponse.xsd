            <xs:element name="processed" type="xs:boolean" default="true"/>            
            <!-- Результат вычисления выражения, полученного после изменения значения переменной -->
            <xs:element name="newValueState" type="dbgcalc:CalculationResultBaseData"/>
            <!-- Текст ошибки для случая, если значение локальной переменной изменить не удалось -->
            <xs:element name="errorDescr" type="xs:base64Binary" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
    </xs:complexType>
    
