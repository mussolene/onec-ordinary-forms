                <xs:sequence>
                    <!-- Идентификатор предмета отладки -->
                    <xs:element name="targetID" type="dbgbase:DebugTargetIdLight"/>
                    <!-- Выражение для вычисления -->
                    <xs:element name="modifyDataPath" type="dbgcalc:CalculationSourceDataStorage" maxOccurs="1"/>
                    <!-- Описание нового значения локальной переменной или свойства контекста -->
                    <xs:element name="newValueInfo" type="dbgcalc:NewValueInfo" minOccurs="1" maxOccurs="1"/>
                    <!-- Время ожидания результата изменения значения переменной, мс-->
                    <!-- Значение по умолчанию: 60 секунд -->
                    <xs:element name="timeout" type="xs:decimal" default="60000"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    
    <!-- Ответ на запрос об изменении значения локальной переменной или свойства контекста -->
    <xs:complexType name="RDBGModifyValueResponse">
