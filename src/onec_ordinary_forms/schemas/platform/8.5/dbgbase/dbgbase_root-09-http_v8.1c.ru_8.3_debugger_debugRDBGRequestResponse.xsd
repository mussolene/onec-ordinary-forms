                    <!-- других остановленных предметов отладки -->
                    <xs:element name="simple" type="xs:boolean" default="false"/>
                    <!-- Идентификатор предмета отладки, который вызвал срабатывание -->
                    <xs:element name="triggeredTargetID" type="dbgbase:DebugTargetIdLight"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    
