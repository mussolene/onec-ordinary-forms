<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:core="http://v8.1c.ru/8.1/data/core"
           xmlns:bsl="http://v8.1c.ru/8.2/data/bsl"
           xmlns:ui="http://v8.1c.ru/8.1/data/ui"
           xmlns:ma="http://v8.1c.ru/8.2/managed-application/core"
           xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform"
           xmlns:dscs="http://v8.1c.ru/8.1/data-composition-system/settings"
           xmlns:tns="http://v8.1c.ru/8.3/mobile-application/form"
           xmlns:ent="http://v8.1c.ru/8.1/data/enterprise"
           xmlns:mxl="http://v8.1c.ru/8.2/data/spreadsheet"
           xmlns:chrt="http://v8.1c.ru/8.2/data/chart"
           xmlns:pln="http://v8.1c.ru/8.3/data/planner"
           targetNamespace="http://v8.1c.ru/8.3/mobile-application/form"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified">
    <xs:import namespace="http://v8.1c.ru/8.1/data/core" schemaLocation="../../../xdto/src/res/core.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/bsl" schemaLocation="../../../bsl/src/res/bsl.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/ui" schemaLocation="../../../xdto/src/res/uiobjects.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/core" schemaLocation="../../../mngcore/src/res/mngapp.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/logform" schemaLocation="../../../mngcore/src/res/logform.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data-composition-system/settings" schemaLocation="../../../dcscore/src/res/settings.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/enterprise" schemaLocation="../../../enums/src/res/enums.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/spreadsheet" schemaLocation="../../../moxel/src/res/spreadsheetDocument.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/chart" schemaLocation="../../../chart/src/res/chart.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.3/data/planner" schemaLocation="../../../plnnr/src/res/plnnr.xsd"/>

    <xs:simpleType name="MDObjReference">
        <!--TODO копия из  MobileApp, нужно поместить в одну из корневых схем -->
        <xs:annotation>
            <xs:documentation>
                Ссылка на объект метаданных. Аналог результата вызова метода ПолноеИмя
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:Name" />
    </xs:simpleType>
    
    <!--TODO реализация AdjustableBoolean содрана из xcf/readable с незначительными изменениями -->
    <xs:complexType name="AdjustableBooleanItemType">
        <xs:simpleContent>
            <xs:extension base="xs:boolean">
                <xs:attribute name="name" type="tns:MDObjReference"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>

    <xs:complexType name="AdjustableBoolean">
        <xs:sequence>
            <xs:element name="common" type="xs:boolean"  minOccurs="0" />
            <xs:element name="value" type="tns:AdjustableBooleanItemType" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="MobileForm">
        <xs:annotation>
            <xs:documentation>Форма мобильного приложения</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="serverModule" type="bsl:BSLModuleImage" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Модуль на сервере</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="clientModule" type="bsl:BSLModuleImage" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Модуль на клиенте</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="serverWOContextModule" type="bsl:BSLModuleImage" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Модуль на сервере без контекста</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="clientServerWOContextModule" type="bsl:BSLModuleImage" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Модуль на клиенте или на сервере без контекста</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="attributes" type="tns:Attributes" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Реквизиты</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="parameter" type="tns:Parameter" maxOccurs="unbounded"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Параметры</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="command" type="tns:Command" maxOccurs="unbounded"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Команды</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="mainElement" type="tns:MainElement">
                <xs:annotation>
                    <xs:documentation>Корневой элемент формы.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="navigationPanel" type="tns:CMIFragmentRecord" maxOccurs="unbounded"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Настройка панели навигации</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="commandPanel" type="tns:CMIFragmentRecord" maxOccurs="unbounded"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Настройка панели команд</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="FieldPath">
        <xs:annotation>
            <xs:documentation>Путь к данным</xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:Name" />
    </xs:simpleType>

    <xs:simpleType name="FieldPathList">
        <xs:list itemType="tns:FieldPath" />
    </xs:simpleType>

    <xs:complexType name="Attributes">
        <xs:annotation>
            <xs:documentation>Реквизиты управляемой формы</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="attribute" type="tns:Attribute" maxOccurs="unbounded"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Реквизиты</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="conditionalAppearance" type="dscs:ConditionalAppearance" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Условное оформление</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Columns">
        <xs:annotation>
            <xs:documentation>Колонки реквизита</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="attribute" type="tns:Attribute" maxOccurs="unbounded"  minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Колонки</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="path" type="tns:FieldPath">
            <xs:annotation>
                <xs:documentation>Относительный путь к реквизиту владельцу от реквизита верхнего уровня</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>

    <xs:complexType name="Column">
        <xs:annotation>
            <xs:documentation>Колонка табличного реквизита</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="title" type="core:LocalStringType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Заголовок</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="type" type="core:TypeDescription">
                <xs:annotation>
                    <xs:documentation>Тип</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="extInformation" type="tns:ExtAttributeInformation" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Дополнительная информация</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="fillChecking" type="core:FillChecking" default= "DontCheck" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Проверка заполнения</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="view" type="tns:AdjustableBoolean" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Просмотр</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="edit" type="tns:AdjustableBoolean" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Редактирование</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="functionalOption" type="tns:MDObjReference" maxOccurs="unbounded" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Функциональные опции</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="name" type="xs:Name" use="required">
            <xs:annotation>
                <xs:documentation>Имя</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>

    <xs:complexType name="Attribute">
        <xs:annotation>
            <xs:documentation>Реквизит управляемой формы</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:Column">
                <xs:sequence>
                    <xs:element name="main" type="xs:boolean" default= "false" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основной реквизит</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="storedData" type="xs:boolean" default= "false" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Сохраняемые данные</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="columns" type="tns:Columns" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Колонки</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <!--Сохранять данные в настройках-->
                    <xs:element name="useAalways" type="tns:FieldPathList">
                        <xs:annotation>
                            <xs:documentation>Использовать всегда</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="ExtAttributeInformation" abstract="true">
        <xs:annotation>
            <xs:documentation>Дополнительная информация о реквизите</xs:documentation>
        </xs:annotation>
    </xs:complexType>

    <xs:complexType name="EAI_ValueList">
        <xs:annotation>
            <xs:documentation>Дополнительная информация о реквизите для типа СписокЗначений</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:ExtAttributeInformation">
                <xs:sequence>
                    <xs:element name="valueType" type="core:TypeDescription">
                        <xs:annotation>
                            <xs:documentation>Тип значения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="EAI_DynamicList">
        <xs:annotation>
            <xs:documentation>Дополнительная информация о реквизите для типа ДинамическийСписок</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:ExtAttributeInformation">
                <xs:sequence>
                    <xs:element name="customQuery" type="xs:boolean" default= "false" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Произвольный запрос</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="queryText" type="xs:string" default= "" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Текст запроса</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="dynamicDataRead" type="xs:boolean" default= "true" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Динамическое считывание данных</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="mainTable" type="tns:MDObjReference" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основная таблица</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="mainTableCategory" type="xs:decimal" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Категория основной таблицы</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="filter" type="dscs:Filter" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Отбор</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="order" type="dscs:Order" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Порядок</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="conditionalAppearance" type="dscs:ConditionalAppearance" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Условное оформление</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="groupItems" type="dscs:GroupItems" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Поля группировки</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="requiredField" type="xs:Name" minOccurs="0" maxOccurs="unbounded">
                        <xs:annotation>
                            <xs:documentation>Обязательные поля</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="EAI_Chart">
        <xs:annotation>
            <xs:documentation>Дополнительная информация о реквизите для табличного документа</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:ExtAttributeInformation">
                <xs:sequence>
                    <xs:element name="value" type="chrt:Chart"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="EAI_SpreadsheetDocument">
        <xs:annotation>
            <xs:documentation>Дополнительная информация о реквизите для табличного документа</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:ExtAttributeInformation">
                <xs:sequence>
                    <xs:element name="value" type="mxl:SpreadsheetDocument"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="EAI_Planner">
        <xs:annotation>
            <xs:documentation>Дополнительная информация о реквизите для планировщика</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:ExtAttributeInformation">
                <xs:sequence>
                    <xs:element name="value" type="pln:Planner"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Parameter">
        <xs:annotation>
            <xs:documentation>Параметр формы</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="type" type="core:TypeDescription">
                <xs:annotation>
                    <xs:documentation>Тип</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="key" type="xs:boolean" default= "false" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Ключевой параметр</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="name" type="xs:Name" use="required">
            <xs:annotation>
                <xs:documentation>Имя</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>

    <xs:complexType name="Command">
        <xs:annotation>
            <xs:documentation>Команда формы</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="title" type="core:LocalStringType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Заголовок</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="handlerName" type="xs:Name" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Имя обработчика</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="modifiesStoredData" type="xs:boolean" default= "false" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Изменяет сохраняемые данные</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="use" type="tns:AdjustableBoolean" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Использование</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="functionalOption" type="tns:MDObjReference" maxOccurs="unbounded" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Функциональные опции</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="picture" type="ui:Picture" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Картинка</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="tooltip" type="core:LocalStringType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Подсказка</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="representation" type="lf:ButtonRepresentation" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Отображение</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="currentRowUse" type="lf:CurrentRowUse" default= "Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Идентификатор связанной таблицы</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="associatedTableElementName" type="xs:Name" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Связь с текущими данными таблицы</xs:documentation>
                </xs:annotation>
            </xs:element>
            <!--Сочетание клавиш -->
        </xs:sequence>
        <xs:attribute name="name" type="xs:Name" use="required">
            <xs:annotation>
                <xs:documentation>Имя</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    
    <xs:complexType name="MainElement">
        <xs:annotation>
            <xs:documentation>Корневой элемент логической формы</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="title" type="core:LocalStringType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Заголовок</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="autoTitle" type="xs:boolean" default= "true" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Авто заголовок</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="autoURL" type="xs:boolean" default= "true" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Признак автоматического формирования навигационной ссылки формы</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="enabled" type="xs:boolean" default= "true" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Доступность</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="grouping" type="lf:FormChildrenGroup" default= "Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Группировка</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="commandBarLocation" type="lf:FormElementCommandBarLocation" default= "Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Положение командной панели</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="autoCommandBar" type="tns:Group" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Командная панель</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="commandsContent" type="tns:CommandsContent" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Состав команд</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="windowOpeningMode" type="lf:OnFormWindowOpenLockMode" minOccurs="0" default= "DontBlock">
                <xs:annotation>
                    <xs:documentation>Режим блокировки при открытии окна формы</xs:documentation>
                </xs:annotation>
            </xs:element>
            <!--Поведение формы при нажатии клавиши Enter-->
            <xs:element name="width" type="xs:decimal" default= "0" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Ширина</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="height" type="xs:decimal" default= "0" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Высота</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="slaveItemsWidth" type="lf:FormChildrenWidth" default= "Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Ширина подчиненных элементов</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="childrenAlign" type="lf:FormChildrenAlign" default="Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Выравнивание подчиненных элементов</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="horizontalSpacing" type="lf:FormItemSpacing" default="Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Горизонтальный интервал</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="verticalSpacing" type="lf:FormItemSpacing" default="Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Вертикальный интервал</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="horizontalAlign" type="lf:ItemHorizontalAlignment" default="Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Горизонтальное положение</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="verticalAlign" type="lf:ItemVerticalAlignment" default="Auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Вертикальное положение</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="windowRepresentationMode" type="lf:FormWindowViewMode" minOccurs="0" default= "Auto">
                <xs:annotation>
                    <xs:documentation>Режим отображения окна формы</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="showCommandBar" type="lf:BWAValue" default= "auto" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Отображать командную панель</xs:documentation>
                </xs:annotation>
            </xs:element>

            <!--дополнительные свойства-->
            <xs:element name="usage" type="ent:FoldersAndItemsUse" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Выбор для групп и элементов</xs:documentation>
                </xs:annotation>
