<?xml version="1.0" encoding="utf-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:core="http://v8.1c.ru/8.1/data/core"
           xmlns:ent="http://v8.1c.ru/8.1/data/enterprise"
           xmlns:ui="http://v8.1c.ru/8.1/data/ui"
           xmlns:bsl="http://v8.1c.ru/8.2/data/bsl"
           xmlns:ma="http://v8.1c.ru/8.2/managed-application/core"
           xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform"
           xmlns:cmi="http://v8.1c.ru/8.2/managed-application/cmi"
           xmlns:mxl="http://v8.1c.ru/8.2/data/spreadsheet"
           xmlns:tns="http://v8.1c.ru/8.3/mobile-application/app"
           xmlns:form="http://v8.1c.ru/8.3/mobile-application/form"
           xmlns:xen="http://v8.1c.ru/8.3/xcf/enums"
           xmlns:xep="http://v8.1c.ru/8.3/xcf/extrnprops"
           xmlns:role="http://v8.1c.ru/8.2/roles"
           xmlns:xer="http://v8.1c.ru/8.3/xcf/readable"
           xmlns:dcssm="http://v8.1c.ru/8.1/data-composition-system/schema"
           targetNamespace="http://v8.1c.ru/8.3/mobile-application/app"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified">
    <xs:import namespace="http://v8.1c.ru/8.1/data/core" schemaLocation="../../../xdto/src/res/core.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/bsl" schemaLocation="../../../bsl/src/res/bsl.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/ui" schemaLocation="../../../xdto/src/res/uiobjects.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.3/mobile-application/form" schemaLocation="MobileForm.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/spreadsheet" schemaLocation="../../../moxel/src/res/spreadsheetDocument.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/core" schemaLocation="../../../mngcore/src/res/mngapp.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/logform" schemaLocation="../../../mngcore/src/res/logform.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/cmi" schemaLocation="../../../mngcore/src/res/cmi.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.3/xcf/enums" schemaLocation="../../../backend/src/res/xcf_enums.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.3/xcf/extrnprops" schemaLocation="../../../backend/src/res/xcf_extprops.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/enterprise" schemaLocation="../../../enums/src/res/enums.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/roles" schemaLocation="../../../backend/src/res/role.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.3/xcf/readable" schemaLocation="../../../backend/src/res/xcf_readable.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data-composition-system/schema" schemaLocation="../../../dcs/src/res/scheme.xsd"/>

    <xs:complexType name="MDBaseObj" abstract="true">
        <xs:sequence>
            <xs:element name="synonym" type="core:LocalStringType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Синонимы</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="comment" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Комментарий </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="generatedType" type="xer:GeneratedType" minOccurs="0" maxOccurs="unbounded">
                <xs:annotation>
                    <xs:documentation>Типы порождаемые на основании этого объекта </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="name" type="xs:Name" use="required">
            <xs:annotation>
                <xs:documentation>Имя</xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="id" type="core:UUID" use="required">
            <xs:annotation>
                <xs:documentation>Идентификатор</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>

    <xs:complexType name="MobileApp">
        <xs:annotation>
            <xs:documentation>Мобильное приложение</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:MDBaseObj">
                <xs:sequence>
                    <xs:element name="language" type="tns:Language" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список языков мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="vendor" type="xs:string" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Поставщик конфигурации.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="briefInformation" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Краткая информация о конфигурации.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="detailedInformation" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Подробная информация о конфигурации.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="logo" type="ui:Picture" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Логотип конфигурации.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="copyright" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Авторские права на конфигурацию.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="vendorInformationAddress" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Адрес информации о поставщике конфигурации.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="configurationInformationAddress" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Адрес информации о конфигурации.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="objectAutonumerationMode" type="xen:ObjectAutonumerationMode"  default= "NotAutoFree" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Режим автонумерации объектов.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="mainModule" type="bsl:BSLModuleImage" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Модуль приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="sessionModule" type="bsl:BSLModuleImage" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Модуль сеанса</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="startPageWorkingArea" type="tns:StartPageWorkingArea" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Рабочая область начальной страницы</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commandInterface" type="tns:CommandInterfaceFragment" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Командный интерфейс</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="defaultRole" type="tns:MDObjReference" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основные роли.</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="defaultReportForm" type="tns:MDObjReference" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основная форма отчета</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="defaultReportSettingsForm" type="tns:MDObjReference" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основная форма настроек отчета</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="defaultReportVariantForm" type="tns:MDObjReference" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основная форма варианта отчета</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="subsystem" type="tns:Subsystem" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Подсистемы мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commonModule" type="tns:CommonModule" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список общих модулей мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commonForm" type="tns:CommonForm" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список общих форм мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commonTemplate" type="tns:CommonTemplate" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список общих макетов мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="sessionParam" type="tns:SessionParam" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список параметров сессии мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>            
                    <xs:element name="exchangePlan" type="tns:ExchangePlan" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список планов обмена мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="eventSubscription" type="tns:EventSubscription" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список подписок на события мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commonCommand" type="tns:CustomCommand" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список общих команд мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commandGroup" type="tns:CommandGroup" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список групп команд мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="commonPicture" type="tns:CommonPicture" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список общих картинок мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="role" type="role:Rights" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список ролей мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="functionalOption" type="tns:FunctionalOption" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список функциональных опций мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="functionalOptionsParameter" type="tns:FunctionalOptionsParameter" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список параметров функциональных опций мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="WSReference" type="tns:WSReference" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список WS-Ссылок мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="constant" type="tns:Constant" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список констант мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="catalog" type="tns:Catalog" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список справочников мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="document" type="tns:Document" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список документов мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="documentNumerator" type="tns:DocumentNumerator" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список нумераторов мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="sequence" type="tns:Sequence" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список последовательностей мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="documentJournal" type="tns:DocumentJournal" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список журналов документов мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="informationRegister" type="tns:InformationRegister" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список регистров сведений мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="accumulationRegister" type="tns:AccumulationRegister" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список регистров накопления мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="enum" type="tns:Enum" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список перечислений мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="dataProcessor" type="tns:DataProcessor" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список обработок мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="requiredPermission" type="ma:RequiredPermission" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Требуемые разрешения мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="applicationURL" type="ma:MobileApplicationURL" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Навигационные ссылки мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="allowedIncomingShareRequestType" type="ma:AllowedIncomingShareRequestType" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Допустимые типы входящих запросов "Поделиться"</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="desktopCommandInterface" type="tns:CommandInterfaceFragment" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Командный интерфейс основного раздела</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="report" type="tns:Report" maxOccurs="unbounded"  minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список отчетов мобильного приложения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="DBNames" type="tns:DBNames" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Имена базы данных</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="FarRef" type="tns:FarRef" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Внешние ссылки</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
                <xs:attribute name="containerID" type="core:UUID" use="required">
                    <xs:annotation>
                        <xs:documentation>Идентификатор контейнера</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="defaultLanguage" type="tns:MDObjReference" use="required">
                    <xs:annotation>
                        <xs:documentation>Основной язык конфигурации</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
                <xs:attribute name="version" type="xs:string">
                    <xs:annotation>
                        <xs:documentation>Версия конфигурации</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
              <xs:attribute name="platformVersion" type="xs:string">
                <xs:annotation>
                  <xs:documentation>Версия платформы</xs:documentation>
                </xs:annotation>
              </xs:attribute>
              <xs:attribute name="scriptVariant" type="xen:ScriptVariant">
                    <xs:annotation>
                        <xs:documentation>Вариант встроенного языка</xs:documentation>
                    </xs:annotation>
              </xs:attribute>
              <xs:attribute name="compatibilityMode" type="xs:string">
                    <xs:annotation>
                        <xs:documentation>Режим совместимости конфигурации</xs:documentation>
                    </xs:annotation>
              </xs:attribute>
                <xs:attribute name="formatVersion" type="xs:decimal">
                    <xs:annotation>
                        <xs:documentation>Версия формата выгрузки</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    
    <xs:simpleType name="MDObjReference">
        <xs:annotation>
            <xs:documentation>
                Ссылка на объект метаданных. Аналог результата вызова метода ПолноеИмя.
            </xs:documentation>
        </xs:annotation>
        <xs:restriction base="xs:Name" />
    </xs:simpleType>

    <xs:complexType name="MDTypedObj" abstract="true">
        <xs:complexContent>
            <xs:extension base="tns:MDBaseObj">
                <xs:sequence>
                    <xs:element name="type" type="core:TypeDescription">
                        <xs:annotation>
                            <xs:documentation>Тип</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Constant">
        <xs:annotation>
            <xs:documentation>Константа мобильного приложения</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:MDPropertyObj">
                <xs:sequence>
                    <xs:element name="valueManagerModule" type="bsl:BSLModuleImage" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Модуль менеджера значения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="useStandardCommands" type="xs:boolean" default= "true" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Использовать стандартные команды</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="defaultForm" type="tns:MDObjReference" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Основная форма</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="explanation" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Пояснение</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="extendedPresentation" type="core:LocalStringType" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Расширенное представление</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Catalog">
        <xs:annotation>
            <xs:documentation>Справочник мобильного приложения</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:MDBaseObj">
                <xs:sequence>
                    <xs:element name="managerModule" type="bsl:BSLModuleImage" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Модуль менеджера</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="objectModule" type="bsl:BSLModuleImage" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Модуль объекта</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="hierarchical" type="xs:boolean" default= "false" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Иерархический</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="hierarchyType" type="xen:HierarchyType" default= "HierarchyFoldersAndItems" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Вид иерархии</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="limitLevelCount" type="xs:boolean" default= "false" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Ограничивать количество уровней</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="levelCount" type="xs:decimal" default= "2" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Количество уровней</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="foldersOnTop" type="xs:boolean" default= "true" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Группы сверху</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="owner" type="tns:MDObjReference" maxOccurs="unbounded" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Список имен владельцев</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="subordinationUse" type="xen:SubordinationUse" default= "ToItems" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Использование подчинения</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="codeLength" type="xs:decimal" default= "9" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Длина кода</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="descriptionLength" type="xs:decimal" default= "25" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Длина наменования</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="codeType" type="xen:CatalogCodeType" default= "String" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Тип кода</xs:documentation>
                        </xs:annotation>
                    </xs:element>
                    <xs:element name="codeAllowedLength" type="core:AllowedLength" default= "Variable" minOccurs="0">
                        <xs:annotation>
                            <xs:documentation>Допустимая длина кода</xs:documentation>
