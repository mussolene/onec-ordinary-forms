            <element name="pivotChartType" type="tns:PivotChartType" />
            <element name="pointsValuesShowMode" type="tns:PivotChartValuesShowMode" />
            <element name="seriesValuesShowMode" type="tns:PivotChartValuesShowMode" />
            <element name="horizontalScaleLabelsOrientation" type="tns:PivotChartLabelsOrientation" />
            <element name="horizontalScaleTopLevelCount" type="decimal" />
            <element name="fieldAreasTransparent" type="boolean" />
            <element name="fieldAreasBackColor" type="v8ui:Color" />
            <element name="fieldAreasTextColor" type="v8ui:Color" />
            <element name="showFields" type="boolean">
                <annotation>
                    <documentation>Отображать диалог выбора полей</documentation>
                </annotation>
            </element>
        </sequence>
    </complexType>

    <complexType name="ChartsViewSettings">
        <sequence>
