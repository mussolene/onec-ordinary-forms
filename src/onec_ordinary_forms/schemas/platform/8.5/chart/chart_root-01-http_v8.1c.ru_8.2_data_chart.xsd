<?xml version="1.0" encoding="UTF-8"?>
<schema 
    xmlns="http://www.w3.org/2001/XMLSchema" 
    targetNamespace="http://v8.1c.ru/8.2/data/chart" 
    xmlns:tns="http://v8.1c.ru/8.2/data/chart"  
    xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" 
    xmlns:core="http://v8.1c.ru/8.1/data/core"
    elementFormDefault="qualified"
    attributeFormDefault="unqualified">

    <import namespace="http://v8.1c.ru/8.1/data/core" schemaLocation="../../../xdto/src/res/core.xsd"/>
    <import namespace="http://v8.1c.ru/8.1/data/ui" schemaLocation="../../../xdto/src/res/uiobjects.xsd"/>

    <simpleType name="ChartLabelLocation">
        <restriction base="string">
            <enumeration value="Edge" />
            <enumeration value="Center" />
            <enumeration value="EdgeInside" />
            <enumeration value="EdgeAuto" />
            <enumeration value="Auto" />
            <enumeration value="LeftBottom" />
            <enumeration value="RightBottom" />
            <enumeration value="LeftTop" />
            <enumeration value="RightTop" />
            <enumeration value="LeftAndTopSpecified" />
            <enumeration value="EmptySpace"/>
        </restriction>
    </simpleType>

    <simpleType name="ChartOrientation">
        <restriction base="string">
            <enumeration value="SouthWest" />
            <enumeration value="SouthEast" />
        </restriction>
    </simpleType>

    <simpleType name="MaxSeries">
        <restriction base="string">
            <enumeration value="NotDefined" />
            <enumeration value="Limited" />
            <enumeration value="Percent" />
        </restriction>
    </simpleType>

    <simpleType name="ChartSpaceMode">
        <restriction base="string">
            <enumeration value="None" />
            <enumeration value="Half" />
            <enumeration value="Full" />
        </restriction>
    </simpleType>

    <simpleType name="ChartMarkerType">
        <restriction base="string">
            <enumeration value="None" />
            <enumeration value="Rect" />
            <enumeration value="Circle" />
            <enumeration value="Rhomb" />
            <enumeration value="Auto" />
            <enumeration value="Alternation" />
        </restriction>
    </simpleType>

    <simpleType name="RadarChartScaleType">
        <restriction base="string">
            <enumeration value="Circle" />
            <enumeration value="Polygon" />
        </restriction>
    </simpleType>

    <simpleType name="GaugeChartValueRepresentation">
        <restriction base="string">
            <enumeration value="Needle" />
            <enumeration value="Sector" />
        </restriction>
    </simpleType>

    <simpleType name="GaugeChartValuesScaleLabelsLocation">
        <restriction base="string">
            <enumeration value="AtScale" />
            <enumeration value="InsideScale" />
        </restriction>
    </simpleType>

    <simpleType name="ChartSplineMode">
      <restriction base="string">
        <enumeration value="None" />
        <enumeration value="SmoothCurve" />
      </restriction>
    </simpleType>

    <simpleType name="ChartSemitransparencyMode">
      <restriction base="string">
        <enumeration value="DontUse" />
        <enumeration value="Use" />
        <enumeration value="Auto" />
      </restriction>
    </simpleType>

  <simpleType name="ChartValuesBySeriesConnectionType">
      <restriction base="string">
        <enumeration value="None" />
        <enumeration value="EdgesConnection" />
      </restriction>
    </simpleType>

    <simpleType name="ChartAnimation">
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Use" />
            <enumeration value="DontUse" />
        </restriction>
    </simpleType>

    <complexType name="DoubleRect">
        <sequence>
            <element name="left" type="decimal" />
            <element name="right" type="decimal" />
            <element name="top" type="decimal" />
            <element name="bottom" type="decimal" />
        </sequence>
    </complexType>

    <simpleType name="ChartTrendlineApproximationType">
        <annotation>
          <documentation>Тип аппроксимации линии тренда</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Linear" />
            <enumeration value="Exponential" />
            <enumeration value="Logarithmic" />
            <enumeration value="Power" />
            <enumeration value="Polynomial" />
        </restriction>
    </simpleType>

    <simpleType name="ChartTrendlineFactor">
        <annotation>
            <documentation>Фактор линии тренда диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="PointNumber" />
            <enumeration value="PointValue" />
            <enumeration value="Auto" />
        </restriction>
    </simpleType>

    <simpleType name="StockChartUsedPointValue">
      <annotation>
        <documentation>Используемое значение точки биржевой диаграммы</documentation>
      </annotation>
      <restriction base="string">
        <enumeration value="Open" />
        <enumeration value="High" />
        <enumeration value="Low" />
        <enumeration value="Close" />
        <enumeration value="OpenCloseAverage" />
      </restriction>
    </simpleType>

    <simpleType name="ShowInChartLegend">
        <annotation>
            <documentation>Режим отображения серии в легенде</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Show" />
            <enumeration value="DontShow" />
        </restriction>
    </simpleType>
  
    <simpleType name="ShowInChart">
        <annotation>
            <documentation>Режим отображения серии при отрисовке диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Show" />
            <enumeration value="DontShow" />
        </restriction>
    </simpleType>

    <simpleType name="ChartSeriesOrderInLegend">
        <annotation>
            <documentation>Порядок отображения серий в легенде диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Direct" />
            <enumeration value="Reverse" />
        </restriction>
    </simpleType>

    <simpleType name="ChartPointsAxisValuesSource">
        <annotation>
            <documentation>Вариант источника значений на оси точек диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Series" />
            <enumeration value="Points" />
        </restriction>
    </simpleType>

    <simpleType name="ChartBubbleSizeValueSource">
        <annotation>
            <documentation>Вариант источника значений размера пузырька в диаграмме</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="None" />
            <enumeration value="CommonSeries" />
            <enumeration value="NextSeries" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartBubbleSizing">
        <annotation>
            <documentation>Вариант вычисления размера пузырька в диаграмме</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="IncreaseDiameter" />
            <enumeration value="IncreaseArea" />
            <enumeration value="DecreaseDiameter" />
            <enumeration value="DecreaseArea" />
        </restriction>
    </simpleType>

    <simpleType name="BubbleChartNegativeValuesShowMode">
        <annotation>
            <documentation>Вариант отображения отрицательных значений в пузырьковой диаграмме</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="DontShow" />
            <enumeration value="Abs" />
            <enumeration value="Transparent" />
            <enumeration value="InvertedBackColor" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartPointsConnectionType">
        <annotation>
            <documentation>Тип соединения точек в диаграмме</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Connect" />
            <enumeration value="DontConnect" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartBoundaryDetectionMethod">
        <annotation>
            <documentation></documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="AutoDetect" />
            <enumeration value="UseValue" />
            <enumeration value="UseValueWithLimitations" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartScaleTitleTextSource">
          <annotation>
              <documentation>Способ заполнения текста заголовка шкалы диаграммы</documentation>
          </annotation>
          <restriction base="string">
              <enumeration value="Auto" />
              <enumeration value="UseText" />
              <enumeration value="AutoText" />
          </restriction>
    </simpleType>
  
    <simpleType name="ShowChartScaleTitle">
          <annotation>
              <documentation>Отображение заголовка шкалы диаграммы</documentation>
          </annotation>
          <restriction base="string">
              <enumeration value="Auto" />
              <enumeration value="DontShow" />
              <enumeration value="Show" />
          </restriction>
    </simpleType>
  
    <simpleType name="ChartScaleTitlePlacement">
          <annotation>
              <documentation>Расположение заголовка шкалы диаграммы</documentation>
          </annotation>
          <restriction base="string">
              <enumeration value="WithAxis" />
              <enumeration value="PlotArea" />
              <enumeration value="SpecialArea" />
          </restriction>
    </simpleType>
  
    <simpleType name="BarChartPointsOrder">
        <annotation>
            <documentation>Порядок отображения точек в горизонтальной диаграмме</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="TopToBottom" />
            <enumeration value="BottomToTop" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartGridLinesShowMode">
        <annotation>
            <documentation>Отображение линий сетки диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="DontShow" />
            <enumeration value="Show" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartScaleLabelLocation">
        <annotation>
            <documentation>Отображение подписей шкалы диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="None" />
            <enumeration value="Inside" />
            <enumeration value="Outside" />
        </restriction>
    </simpleType>
    
    <simpleType name="ChartScaleLocation">
        <annotation>
            <documentation>Положение шкалы диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="BaseValue" />
            <enumeration value="Edge" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartScaleMarkLocation">
        <annotation>
            <documentation>Положение отметки шкалы диагарммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Outside" />
            <enumeration value="Inside" />
            <enumeration value="Center" />
            <enumeration value="None" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartLegendPlacement">
        <annotation>
            <documentation>Расположение легенды диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Top" />
            <enumeration value="Left" />
            <enumeration value="Bottom" />
            <enumeration value="Right" />
            <enumeration value="UseCoordinates" />
            <enumeration value="None" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartPlotAreaPlacement">
        <annotation>
            <documentation>Расположение области построения диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="UseCoordinates" />
            <enumeration value="EmptySpace" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartTitleAreaPlacement">
        <annotation>
            <documentation>Расположение области заголовка диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="LeftBottom" />
            <enumeration value="LeftTop" />
            <enumeration value="RightBottom" />
            <enumeration value="RightTop" />
            <enumeration value="Bottom" />
            <enumeration value="UseCoordinates" />
            <enumeration value="None" />
            <enumeration value="Top" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartReferenceLinePosition">
        <annotation>
            <documentation>Положение информационной линии диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="OnValue" />
            <enumeration value="BetweenValues" />
        </restriction>
    </simpleType>
  
    <simpleType name="ChartReferenceBandBorderPosition">
        <annotation>
            <documentation>Положение границы информационного интервала диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="OnValue" />
            <enumeration value="BetweenValues" />
        </restriction>
    </simpleType>
    
    <simpleType name="NonnumericChartValueUse">
        <annotation>
            <documentation>Использование нечисловых значений диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="AsZero" />
            <enumeration value="Skip" />
        </restriction>
    </simpleType>
  
    <simpleType name="PointsConnectionAcrossSkippedChartValuesType">
        <annotation>
            <documentation>Тип соединения точек при пропущенных значениях диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="None" />
            <enumeration value="ConnectUnskippedValues" />
            <enumeration value="ConnectWithBaseValue" />
        </restriction>
    </simpleType>
    
    <simpleType name="ChartValuesToolTipShowMode">
        <annotation>
            <documentation>Режим отображения подсказки значений диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="ShowForNearestValue" />
            <enumeration value="ShowOnHover" />
            <enumeration value="DontShow" />
        </restriction>
    </simpleType>

    <simpleType name="ChartValuesToolTipFillType">
        <annotation>
            <documentation>Заполнение подсказки значений диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="SingleValue" />
            <enumeration value="AllPointValues" />
        </restriction>
    </simpleType>

    <simpleType name="ChartSelectionMode">
        <annotation>
            <documentation>Режим выделения диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="ValuesSelection" />
            <enumeration value="PointsSelection" />
            <enumeration value="None" />
        </restriction>
    </simpleType>
    
    <simpleType name="ShowChartPopupReferenceLine">
        <annotation>
            <documentation>Отображение направлящих подсказки диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Show" />
            <enumeration value="DontShow" />
        </restriction>
    </simpleType>
        
    <simpleType name="ChartSeriesGraphicalRepresentationType">
        <annotation>
            <documentation>Тип графического представления серии диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Line" />
            <enumeration value="Step" />
            <enumeration value="Area" />
            <enumeration value="Column" />
            <enumeration value="Column3D" />
        </restriction>
    </simpleType>
            
    <simpleType name="ChartSeriesStackType">
        <annotation>
            <documentation>Тип накопления серии диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Unstacked" />
            <enumeration value="Stacked" />
            <enumeration value="StackedNormalized" />
        </restriction>
    </simpleType>        
    
    <simpleType name="UsedChartValuesAxis">
        <annotation>
            <documentation>Используемая ось значений диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Main" />
            <enumeration value="Additional" />
        </restriction>
    </simpleType>
    
    <simpleType name="ChartValuesEditMode">
        <annotation>
            <documentation>Режим редактирования значений диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="Auto" />
            <enumeration value="Use" />
            <enumeration value="DontUse" />
        </restriction>
    </simpleType>
    
    <simpleType name="ChartValueEditState">
        <annotation>
            <documentation>Состояние редактирования значения диаграммы</documentation>
        </annotation>
        <restriction base="string">
            <enumeration value="InProgress" />
            <enumeration value="Completed" />
            <enumeration value="Canceled" />
        </restriction>
    </simpleType>
            
    <complexType name="ChartColorPaletteDescription">
        <sequence>
            <element name="colorPalette" type="v8ui:ChartColorPalette" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="gradientPaletteStartColor" type="v8ui:Color" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="gradientPaletteEndColor" type="v8ui:Color" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="gradientPaletteMaxColors" type="decimal" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: 0</documentation>
                </annotation>
            </element>
            <element name="customPalette" type="core:Array" maxOccurs="1" minOccurs="0" >
                <annotation>
                    <documentation>Значение по умолчанию:  nil</documentation>
                </annotation>
            </element>
        </sequence>
    </complexType>
  
    <complexType name="ChartLabelArea">
        <sequence>
            <element name="location" type="tns:ChartLabelLocation" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию:  Auto</documentation>
                </annotation>
            </element>
            <element name="left" type="decimal" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: 0.5</documentation>
                </annotation>
            </element>
            <element name="top" type="decimal" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: 0.5</documentation>
                </annotation>
            </element>
            <element name="font" type="v8ui:Font" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="textColor" type="v8ui:Color" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="backColor" type="v8ui:Color" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="transparent" type="boolean" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: true</documentation>
                </annotation>
            </element>
            <element name="border" type="v8ui:Border" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: НетРамки</documentation>
                </annotation>
            </element>
            <element name="borderColor" type="v8ui:Color" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: true</documentation>
                </annotation>
            </element>
            <element name="marker" type="tns:ChartMarkerType" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="orientation" type="v8ui:ChartLabelsOrientation" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="angle" type="decimal" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: 0</documentation>
                </annotation>
            </element>
        </sequence>
    </complexType>
    
    <complexType name="ChartReferenceLine">
        <sequence>
            <element name="value" type="anyType" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: nil</documentation>
                </annotation>
            </element>
            <element name="valueIsPointNumber" type="boolean" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: false</documentation>
                </annotation>
            </element>
            <element name="labelText" type="core:LocalStringType" maxOccurs="1" minOccurs="0" >
                <annotation>
                    <documentation>Значение по умолчанию: пусто</documentation>
                </annotation>
            </element>
            <element name="toolTip" type="core:LocalStringType" maxOccurs="1" minOccurs="0" >
                <annotation>
                    <documentation>Значение по умолчанию: пусто</documentation>
                </annotation>
            </element>
            <element name="labelArea" type="tns:ChartLabelArea" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию равно значению по умолчанию для типа ChartLabelArea</documentation>
                </annotation>
            </element>
            <element name="line" type="v8ui:Line" maxOccurs="1" minOccurs="0" >
                <annotation>
                    <documentation>Значение по умолчанию: Сплошная, толщина 2</documentation>
                </annotation>
            </element>
            <element name="color" type="v8ui:Color" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
            <element name="semitransparencyPercent" type="decimal" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Неопределенно</documentation>
                </annotation>
            </element>
            <element name="details" type="anyType" maxOccurs="1" minOccurs="0" >
                <annotation>
                    <documentation>Значение по умолчанию: nil</documentation>
                </annotation>
            </element>
            <element name="position" type="tns:ChartReferenceLinePosition" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: Auto</documentation>
                </annotation>
            </element>
        </sequence>
    </complexType>
    
    <complexType name="ChartReferenceLines">
        <sequence>
            <element name="referenceLine" type="tns:ChartReferenceLine" maxOccurs="unbounded" minOccurs="0" />
        </sequence>
    </complexType>
    
    <complexType name="ChartReferenceBand">
        <sequence>
            <element name="begin" type="anyType" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: nil</documentation>
                </annotation>
            </element>
            <element name="beginIsPointNumber" type="boolean" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: false</documentation>
                </annotation>
            </element>
            <element name="end" type="anyType" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: nil</documentation>
                </annotation>
            </element>
            <element name="endIsPointNumber" type="boolean" maxOccurs="1" minOccurs="0">
                <annotation>
                    <documentation>Значение по умолчанию: false</documentation>
