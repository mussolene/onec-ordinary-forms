    <complexType name="DendrogramDimensionValue">
        <sequence>
            <element name="itemKey" type="decimal" />
            <element name="key" type="decimal" />
            <element name="parentKey" type="decimal" />
            <element name="leftKey" type="decimal" />
            <element name="rightKey" type="decimal" />
            <element name="extKey" type="decimal" />
            <element name="valueKey" type="anyType"  maxOccurs="1" minOccurs="0" />
