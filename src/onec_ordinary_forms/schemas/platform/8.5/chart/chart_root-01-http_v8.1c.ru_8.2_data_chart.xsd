            <element name="details" type="anyType"  maxOccurs="1" minOccurs="0" />
            <element name="cacheKey" type="decimal" />
            <element name="baseData" type="decimal" />
            <element name="firstElementKey" type="decimal" />
            <element name="secondElementKey" type="decimal" />
