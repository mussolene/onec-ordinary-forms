    <complexType name="Dendrogram">
        <sequence>
            <element name="chart" type="tns:Chart" />
            <element name="elements" type="tns:DendrogramElements" />
            <element name="links" type="tns:DendrogramLinks" />
            <element name="orientation" type="tns:DendrogramOrientation" />
            <element name="scaleType" type="tns:DendrogramScaleKeeping" />
            <element name="countElements" type="decimal" />
            <element name="fixedMinWidthElement" type="decimal" />
            <element name="lineColor" type="v8ui:Color" />            
            <element name="line" type="v8ui:Line" />            
            <element name="verticalLabels" type="boolean" />
        </sequence>
    </complexType>

    <complexType name="PivotChart">
        <sequence>
            <element name="chart" type="tns:Chart" />
            <element name="horizontalScaleKeeping" type="tns:PivotChartScaleKeeping" />
            <choice minOccurs="0">
                <annotation>
                    <documentation>
                        Данные элементы могут появляться только при значении
                        horizontalScaleKeeping отличном от AllValues
                    </documentation>
                </annotation>
                <element name="horizontalScaleValueCount" type="decimal">
                    <annotation>
                        <documentation>для ValuesCount</documentation>
                    </annotation>
                </element>
                <element name="horizontalScaleValueMinWidth" type="decimal" minOccurs="0">
                    <annotation>
                        <documentation>для MinimumWidth</documentation>
