    <xs:simpleType name="ControlCategory">
    <!-- В языке нет -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="Prim" />
            <xs:enumeration value="Sec" />
        </xs:restriction>
    </xs:simpleType>

    <xs:simpleType name="ItemHorizontalAlignment">
    <!-- В языке есть -->
        <xs:restriction base="xs:string">
            <xs:enumeration value="Left" />
