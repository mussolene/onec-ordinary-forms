  <xs:simpleType name="SearchOnInputForbiddenMode">
    <!-- В языке нет -->
    <xs:restriction base="xs:string">
      <xs:enumeration value="Allow" />
      <xs:enumeration value="Forbidden" />
      <xs:enumeration value="Check" />
    </xs:restriction>
  </xs:simpleType>

    <xs:complexType name="Item" abstract="true">
        <xs:sequence>
            <!-- m_title по умолчанию пустой -->
            <xs:element name="title" type="xs:string" minOccurs="0" />
        </xs:sequence>
        <!-- m_name по умолчанию пустое -->
        <xs:attribute name="name" type="xs:string" />
        <!-- m_logFormElementName по умолчанию == m_name-->
        <xs:attribute name="formItem" type="xs:string" />
        <!-- m_category по умолчанию см. в каждом типе -->
        <xs:attribute name="cat" type="tns:ControlCategory" />
        <!-- m_top по умолчанию 0 -->
        <xs:attribute name="top" type="xs:decimal" />
        <!-- m_left по умолчанию 0 -->
        <xs:attribute name="left" type="xs:decimal" />
        <!-- m_width по умолчанию см. в каждом типе -->
        <xs:attribute name="width" type="xs:decimal" />
        <!-- m_height по умолчанию см. в каждом типе -->
        <xs:attribute name="height" type="xs:decimal" />
        <!-- m_stretchableMode по умолчанию см. в каждом типе -->
        <xs:attribute name="stretch" type="tns:StretchableMode" />
        <!-- m_enabled по умолчанию true -->
        <xs:attribute name="enabled" type="xs:boolean" />
        <!-- m_readOnly по умолчанию false -->
        <xs:attribute name="readOnly" type="xs:boolean" />
        <!-- m_columnIndex по умолчанию 1 -->
        <xs:attribute name="col" type="xs:decimal" />
        <!-- m_skipOnInput по умолчанию false -->
        <xs:attribute name="skip" type="xs:boolean" />
        <!-- m_defaultControl по умолчанию false -->
        <xs:attribute name="def" type="xs:boolean" />
    </xs:complexType>

    <xs:complexType name="Form">
        <xs:complexContent>
            <xs:extension base="tns:Item">
            <!-- умолчания из Item:
                 m_category == Sec 
                 m_width == 0
                 m_height == 0 
                 m_stretchableMode == No -->
                <xs:sequence>
                    <xs:choice minOccurs="0" maxOccurs="unbounded" >
                        <xs:element name="lbl" type="tns:Label" />
                        <xs:element name="txt" type="tns:TextBox" />
                        <xs:element name="chk" type="tns:CheckBox" />
                        <xs:element name="btn" type="tns:Button" />
                        <xs:element name="rbtn" type="tns:RadioButton" />
                        <xs:element name="cmdb" type="tns:CommandBar" />
                        <xs:element name="tbl" type="tns:TableBox" />
                        <xs:element name="grpb" type="tns:GroupBox" />
                        <xs:element name="pnl" type="tns:Panel" />
                        <xs:element name="img" type="tns:Image" />
                        <xs:element name="sep" type="tns:Separator" />
                        <xs:element name="sprdsht" type="tns:Spreadsheet" />
                        <xs:element name="txtd" type="tns:TextDocument" />
                        <xs:element name="fmtd" type="tns:FormattedDocument" />
                        <xs:element name="clndr" type="tns:Calendar" />
                        <xs:element name="prgb" type="tns:ProgressBar" />
                        <xs:element name="trckb" type="tns:TrackBar" />
                        <xs:element name="chrt" type="tns:Chart" />
                        <xs:element name="gchrt" type="tns:GanttChart" />
                        <xs:element name="dndrgm" type="tns:Dendrogram" />
                        <xs:element name="flwchrt" type="tns:Flowchart" />
                        <xs:element name="html" type="tns:HTML" />
                        <xs:element name="gm" type="tns:GeographicalMap" />
                        <xs:element name="empt" type="tns:EmptyElement" />
                        <xs:element name="nvg" type="tns:Navigator" />
                    </xs:choice>
                </xs:sequence>
                <!-- m_realHeight по умолчанию 0 -->
                <xs:attribute name="realHeight" type="xs:decimal" />
                <!-- m_enterKeyBehavior по умолчанию ControlNavigation -->
                <xs:attribute name="enter" type="tns:FormEnterKeyBehavior" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="FormChangesRemoved">
        <xs:sequence>
            <xs:element name="item" type="tns:FormChangesRemovedItem" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FormChangesRemovedItem">
        <xs:sequence>
        </xs:sequence>
        <xs:attribute name="name" type="xs:string"/>
    </xs:complexType>

    <xs:complexType name="FormChangesAddedItem">
        <xs:sequence>
            <xs:element name="type" type="v81:UUID"/>
        </xs:sequence>
        <xs:attribute name="name" type="xs:string"/>
        <xs:attribute name="pname" type="xs:string"/>
        <xs:attribute name="aname" type="xs:string"/>
    </xs:complexType>

    <xs:complexType name="FormChangesAdded">
        <xs:sequence>
            <xs:element name="item" type="tns:FormChangesAddedItem" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FormChangesChangedItem">
        <xs:sequence>
            <xs:choice minOccurs="0" maxOccurs="unbounded" >
                <xs:element name="frm" type="tns:Form" />
                <xs:element name="lbl" type="tns:Label" />
                <xs:element name="txt" type="tns:TextBox" />
                <xs:element name="chk" type="tns:CheckBox" />
                <xs:element name="btn" type="tns:Button" />
                <xs:element name="rbtn" type="tns:RadioButton" />
                <xs:element name="cmdb" type="tns:CommandBar" />
                <xs:element name="cmd" type="tns:Command" />
                <xs:element name="menu" type="tns:Submenu" />
                <xs:element name="msep" type="tns:MenuSeparator" />
                <xs:element name="cntm" type="tns:ContextMenu" />
                <xs:element name="tbl" type="tns:TableBox" />
                <xs:element name="column" type="tns:TableColumn" />
                <xs:element name="group" type="tns:TableColumnsGroup" />
                <xs:element name="grpb" type="tns:GroupBox" />
                <xs:element name="pnl" type="tns:Panel" />
                <xs:element name="page" type="tns:Page" />
                <xs:element name="img" type="tns:Image" />
                <xs:element name="sep" type="tns:Separator" />
                <xs:element name="sprdsht" type="tns:Spreadsheet" />
                <xs:element name="txtd" type="tns:TextDocument" />
                <xs:element name="fmtd" type="tns:FormattedDocument" />
                <xs:element name="clndr" type="tns:Calendar" />
                <xs:element name="prgb" type="tns:ProgressBar" />
                <xs:element name="trckb" type="tns:TrackBar" />
                <xs:element name="chrt" type="tns:Chart" />
                <xs:element name="gchrt" type="tns:GanttChart" />
                <xs:element name="dndrgm" type="tns:Dendrogram" />
                <xs:element name="flwchrt" type="tns:Flowchart" />
                <xs:element name="html" type="tns:HTML" />
                <xs:element name="gm" type="tns:GeographicalMap" />
                <xs:element name="empt" type="tns:EmptyElement" />
