            </xs:choice>
        </xs:sequence>
        <xs:attribute name="name" type="xs:string"/>
        <!-- Если передаётся, то имеем дело с изменением DifferenceKind::eChangedElement. -->
        <xs:attribute name="chtype" type="v81:UUID" />
    </xs:complexType>

    <xs:complexType name="FormChangesChanged">
        <xs:sequence>
            <xs:element name="item" type="tns:FormChangesChangedItem" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FormChangesMovedItem">
        <xs:sequence>
        </xs:sequence>
        <xs:attribute name="name" type="xs:string"/>
        <xs:attribute name="pname" type="xs:string"/>
        <xs:attribute name="aname" type="xs:string"/>
    </xs:complexType>

    <xs:complexType name="FormChangesMoved">
        <xs:sequence>
            <xs:element name="item" type="tns:FormChangesMovedItem" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FormChangesShifted">
        <xs:sequence>
            <xs:element name="item" type="tns:FormChangesShiftedItem" minOccurs="0" maxOccurs="unbounded"/>
