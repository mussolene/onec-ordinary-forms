    </xs:complexType>

    <xs:complexType name="Command">
        <xs:complexContent>
            <xs:extension base="tns:Item">
            <!-- умолчания из Item:
                 m_category == Sec 
                 m_width == 0
                 m_height == 0 
                 m_stretchableMode == No -->
                <xs:sequence>
                    <!-- m_tooltip по умолчанию пустой -->
                    <xs:element name="tooltip" type="xs:string" minOccurs="0" />
                    <!-- m_shortCut по умолчанию ShortCut() -->
                    <xs:element name="shortCut" type="ui:ShortCutType" minOccurs="0" />
                    <!-- m_picture по умолчанию V8Picture() -->
                    <xs:element name="pic" type="ui:Picture" minOccurs="0" />
                </xs:sequence>
                <!-- m_representation по умолчанию Picture -->
                <xs:attribute name="repres" type="tns:MenuElementRepresentation" />
                <!-- m_defaultButton по умолчанию false -->
                <xs:attribute name="defBtn" type="xs:boolean" />
                <!-- m_important по умолчанию true -->
                <xs:attribute name="important" type="xs:boolean" />
                <!-- m_right по умолчанию false -->
                <xs:attribute name="right" type="xs:boolean" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Submenu">
        <xs:complexContent>
            <xs:extension base="tns:Item">
            <!-- умолчания из Item:
                 m_category == Sec 
                 m_width == 0
                 m_height == 0 
                 m_stretchableMode == No -->
                <xs:sequence>
                    <!-- m_tooltip по умолчанию пустой -->
                    <xs:element name="tooltip" type="xs:string" minOccurs="0" />
                    <!-- m_picture по умолчанию V8Picture() -->
                    <xs:element name="pic" type="ui:Picture" minOccurs="0" />
                    <!-- m_shortCut по умолчанию ShortCut() -->
                    <xs:element name="stcut" type="ui:ShortCutType" minOccurs="0" />
                    <xs:element name="groupId" type="v81:CompositeID"/>                  
                    <xs:choice minOccurs="0" maxOccurs="unbounded" >
                        <xs:element name="cmd" type="tns:Command" />
                        <xs:element name="menu" type="tns:Submenu" />
                        <xs:element name="msep" type="tns:MenuSeparator" />
                    </xs:choice>
                </xs:sequence>
                <!-- m_representation по умолчанию Text -->
                <xs:attribute name="repres" type="tns:MenuElementRepresentation" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="MenuSeparator">
        <xs:complexContent>
            <xs:extension base="tns:Item">
            <!-- умолчания из Item:
                 m_category == Sec 
                 m_width == 0
                 m_height == 0 
                 m_stretchableMode == No -->
                <!-- m_autoSeparator по умолчанию true -->
                <xs:attribute name="auto" type="xs:boolean" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="CommandBar">
        <xs:complexContent>
            <xs:extension base="tns:Item">
            <!-- умолчания из Item:
                 m_category == Prim 
                 m_width == 0
                 m_height == 1 
                 m_stretchableMode == Hor -->
                <xs:sequence>
                    <xs:choice minOccurs="0" maxOccurs="unbounded" >
                        <xs:element name="cmd" type="tns:Command" />
                        <xs:element name="menu" type="tns:Submenu" />
                        <xs:element name="msep" type="tns:MenuSeparator" />
                    </xs:choice>
                    <!-- m_shortCut по умолчанию ShortCut() -->
                    <xs:element name="stcut" type="ui:ShortCutType" minOccurs="0" />
                </xs:sequence>
                <!-- m_defaultComandSourceName по умолчанию пустой -->
                <xs:attribute name="source" type="xs:string" />
                <!-- m_hAlign по умолчанию Left -->
                <xs:attribute name="hAlign" type="tns:ItemHorizontalAlignment" />
                <!-- m_secondaryCommandBar по умолчанию true -->
                <xs:attribute name="secCB" type="xs:boolean" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="ContextMenu">
        <xs:complexContent>
            <xs:extension base="tns:Item">
            <!-- умолчания из Item:
                 m_category == Sec 
                 m_width == 0
                 m_height == 0 
                 m_stretchableMode == No -->
                <xs:sequence>
                    <xs:choice minOccurs="0" maxOccurs="unbounded" >
                        <xs:element name="cmd" type="tns:Command" />
                        <xs:element name="menu" type="tns:Submenu" />
                        <xs:element name="msep" type="tns:MenuSeparator" />
                    </xs:choice>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Navigator">
        <xs:complexContent>
            <xs:extension base="tns:Item">
                <!-- умолчания из Item:
                 m_category == Sec 
                 m_width == 0
                 m_height == 0 
                 m_stretchableMode == No -->
                <xs:sequence>
                    <xs:choice minOccurs="0" maxOccurs="unbounded" >
