    </xs:complexType>

    <xs:complexType name="HTMLChangesItem">
        <xs:sequence>
        </xs:sequence>
        <xs:attribute name="pos" type="xs:decimal"/>
        <xs:attribute name="ins" type="xs:string"/>
        <xs:attribute name="del" type="xs:decimal"/>
    </xs:complexType>

    <xs:complexType name="HTMLChanges">
        <xs:sequence>
            <xs:element name="item" type="tns:HTMLChangesItem" minOccurs="0" maxOccurs="unbounded"/>
