    <xs:complexType name="FormChanges">
        <xs:sequence>
            <xs:element name="removed" type="tns:FormChangesRemoved" minOccurs="0" maxOccurs="1"/>
            <xs:element name="added" type="tns:FormChangesAdded" minOccurs="0" maxOccurs="1"/>
            <xs:element name="changed" type="tns:FormChangesChanged" minOccurs="0" maxOccurs="1"/>
            <xs:element name="moved" type="tns:FormChangesMoved" minOccurs="0" maxOccurs="1"/>
            <xs:element name="shifted" type="tns:FormChangesShifted" minOccurs="0" maxOccurs="1"/>
