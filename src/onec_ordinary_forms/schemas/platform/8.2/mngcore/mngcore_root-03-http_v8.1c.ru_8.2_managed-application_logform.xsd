            <!-- m_propertyName по умолчанию empty() -->
            <xs:element name="propName" type="xs:string" minOccurs="0" />
            <!-- m_tdp по умолчанию types().empty() -->
            <xs:element name="tdp" type="v81:TypeDescription" minOccurs="0" />
