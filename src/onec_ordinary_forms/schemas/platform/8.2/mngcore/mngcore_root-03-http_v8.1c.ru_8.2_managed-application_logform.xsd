    <xs:complexType name="Command">
        <xs:sequence>
            <!-- m_id -->
            <xs:element name="id" type="v81:CompositeID" />
        </xs:sequence>
        <!-- m_name по умолчанию пустое -->
        <xs:attribute name="name" type="xs:string"/>
        <!-- m_handlerName по умолчанию пустое -->
        <xs:attribute name="handler" type="xs:string"/>
        <!-- m_modifiesStoredData по умолчанию false -->
        <xs:attribute name="modifiesData" type="xs:boolean"/>
    </xs:complexType>

    <xs:complexType name="Property">
        <xs:sequence>
            <xs:element name="savingContent" type="tns:DataPath" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
        <!-- m_id -->
        <xs:attribute name="id" type="v81:CompositeID" />
        <!-- m_mainProperty по умолчанию false -->
        <xs:attribute name="main" type="xs:boolean"/>
        <!-- m_storedData по умолчанию false -->
        <xs:attribute name="storedData" type="xs:boolean"/>
    </xs:complexType>

    <xs:complexType name="Event">
        <xs:sequence>
            <!-- id по умолчанию kUUIDNull -->
