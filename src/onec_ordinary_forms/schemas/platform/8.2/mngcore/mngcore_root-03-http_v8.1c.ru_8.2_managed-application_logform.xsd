        <xs:attribute name="userVisible" type="xs:boolean"/>
        <!-- m_titleLocation по умолчанию Auto -->
        <xs:attribute name="titleLocation" type="tns:FormElementTitleLocation" />
        <!-- m_titleRowsCount по умолчанию 0 -->
        <xs:attribute name="titleRowsCount" type="xs:decimal" />
        <!-- m_enabled по умолчанию true -->
        <xs:attribute name="enabled" type="xs:boolean" />
        <!-- m_cellHyperlink по умолчанию true -->
        <xs:attribute name="cellHyper" type="xs:boolean" />
        <!-- m_readOnly по умолчанию false -->
        <xs:attribute name="readOnly" type="xs:boolean" />
        <!-- m_skipOnInput по умолчанию auto -->
        <xs:attribute name="skipOnInput" type="tns:BWAValue" />
        <!-- m_defaultElement по умолчанию false -->
        <xs:attribute name="defItem" type="xs:boolean" />
        <!-- m_warningOnEditRepresentation по умолчанию Auto -->
        <xs:attribute name="warningOnEditRepresentation" type="tns:WarningOnEditRepresentation" />
        <!-- m_warningOnEdit по умолчанию пустой -->
        <xs:attribute name="warningOnEdit" type="xs:string" />
        <!-- m_footerText по умолчанию пустой
             брать только строку из языка # -->
        <xs:attribute name="footerText" type="xs:string" />
        <!-- m_showInHeader по умолчанию true -->
        <xs:attribute name="showInHeader" type="xs:boolean" />
        <!-- m_showInFooter по умолчанию true -->
        <xs:attribute name="showInFooter" type="xs:boolean" />
        <!-- m_hAlign по умолчанию Auto -->
        <xs:attribute name="hAlign" type="tns:ItemHorizontalAlignment" />
        <!-- m_headerHAlign по умолчанию Left -->
        <xs:attribute name="headerHAlign" type="tns:ItemHorizontalAlignment" />
        <!-- m_footerHAlign по умолчанию Auto -->
        <xs:attribute name="footerHAlign" type="tns:ItemHorizontalAlignment" />
        <!-- m_vAlign по умолчанию Auto -->
        <xs:attribute name="vAlign" type="tns:ItemVerticalAlignment" />
        <!-- m_columnEditMode по умолчанию Enter -->
        <xs:attribute name="columnEditMode" type="tns:TableFieldEditMode" />
        <!-- m_autoCellHeight по умолчанию false -->
        <xs:attribute name="autoCellHeight" type="xs:boolean" />
        <!-- m_fixedInTable по умолчанию kLogFormFieldDefFixedInTable -->
        <xs:attribute name="fixedInTable" type="tns:FormFixedInTable" />
    </xs:complexType>

    <xs:complexType name="Decoration">
        <xs:sequence>
            <!-- m_textColor по умолчанию kLogFormDecorationDefTextColor -->
            <xs:element name="txtClr" type="ui:Color" minOccurs="0" />
            <!-- m_font по умолчанию kLogFormDecorationDefFont -->
            <xs:element name="fnt" type="ui:Font" minOccurs="0" />
            <!-- m_shortCut по умолчанию ShortCut() -->
            <xs:element name="stcut" type="ui:ShortCutType" minOccurs="0" />
            <xs:choice minOccurs="0" maxOccurs="1" >
                <xs:element name="textData" type="tns:TextDecorationData" />
                <xs:element name="pictureData" type="tns:PictureDecorationData" />
            </xs:choice>
            <!-- m_pContextMenu если оно не пустое и у его данных установлен fillStd
                 иначе только его id -->
            <xs:choice>
                <xs:element name="contextMenu" type="tns:Group" />
                <xs:element name="contextMenuId" type="xs:decimal" />
            </xs:choice>
            <!-- m_title по умолчанию пустой
                 брать только строку из языка # -->
            <xs:element name="title" type="xs:string" minOccurs="0" />
            <!-- m_tooltip по умолчанию пустой
                 брать только строку из языка # -->
            <xs:element name="tooltip" type="xs:string" minOccurs="0" />
        </xs:sequence>
        <!-- m_id Пишется только long. uuid - константа -->
        <xs:attribute name="id" type="xs:decimal" />
        <!-- m_name -->
        <xs:attribute name="name" type="xs:string" />
        <!-- m_origin по умолчанию eSource -->
        <xs:attribute name="org" type="tns:FormElementOrigin" />
        <!-- m_createdByUser по умолчанию false -->
        <xs:attribute name="users" type="xs:boolean" />
        <!-- m_kind -->
        <xs:attribute name="kind" type="tns:ManagedFormDecorationType" />
        <!-- m_visible по умолчанию true -->
        <xs:attribute name="visible" type="xs:boolean"/>
        <!-- m_pUserVisible сериализовать как bool значение брать из commonValue
             по умолчанию true -->
        <xs:attribute name="userVisible" type="xs:boolean"/>
        <!-- m_enabled по умолчанию true -->
        <xs:attribute name="enabled" type="xs:boolean" />
        <!-- m_width по умолчанию 0 -->
        <xs:attribute name="width" type="xs:decimal" />
        <!-- m_height по умолчанию 0 -->
        <xs:attribute name="height" type="xs:decimal" />
        <!-- m_horStretchable по умолчанию auto -->
        <xs:attribute name="horStretch" type="tns:BWAValue" />
        <!-- m_verStretchable по умолчанию auto -->
        <xs:attribute name="verStretch" type="tns:BWAValue" />
        <!-- m_skipOnInput по умолчанию auto -->
        <xs:attribute name="skipOnInput" type="tns:BWAValue" />
    </xs:complexType>


    <xs:complexType name="ElementsChangesItem">
        <xs:sequence>
            <xs:element name="guid" type="v81:UUID"/>
            <xs:choice minOccurs="1" maxOccurs="1">
                <xs:element name="main" type="tns:MainElement"/>
                <xs:element name="field" type="tns:Field"/>
                <xs:element name="group" type="tns:Group"/>
                <xs:element name="table" type="tns:Table"/>
                <xs:element name="button" type="tns:Button"/>
                <xs:element name="decoration" type="tns:Decoration"/>
            </xs:choice>
        </xs:sequence>
        <xs:attribute name="type" type="xs:decimal"/>
        <xs:attribute name="id" type="xs:decimal"/>
        <xs:attribute name="name" type="xs:string"/>
        <xs:attribute name="pid" type="xs:decimal"/>
        <xs:attribute name="aid" type="xs:decimal"/>
    </xs:complexType>

    <xs:complexType name="ElementsChanges">
        <xs:sequence>
            <xs:element name="elemcs" type="tns:ElementsChangesItem" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="MainElement">
        <xs:sequence>
            <!-- m_settingsStorage по умолчанию kUUIDNull -->
            <xs:element name="storage" type="v81:UUID" minOccurs="0" />
            <!-- m_additionalProperties если не пустые-->
            <xs:element name="addProps" type="tns:AddProps" minOccurs="0" />
            <!-- m_elementEvents если не пустые-->
            <xs:element name="event" type="tns:Event" minOccurs="0" maxOccurs="unbounded" />
            <!-- m_commands если не пустые-->
            <xs:element name="commands" type="tns:CommandsInclusion"/>
            <!-- m_pNavigator если m_pNavigator не пустой-->
            <xs:element name="navigator" type="tns:Group" minOccurs="0" />
            <!-- m_pCommandBar если m_pCommandBar пустой и у его данных установлен fillStd -->
            <xs:element name="autoCommandBar" type="tns:Group" minOccurs="0" />
            <xs:choice minOccurs="0" maxOccurs="unbounded">
                <xs:element name="field" type="tns:Field"/>
                <xs:element name="group" type="tns:Group"/>
                <xs:element name="table" type="tns:Table"/>
                <xs:element name="button" type="tns:Button"/>
                <xs:element name="decoration" type="tns:Decoration" />
            </xs:choice>
            <!-- m_title по умолчанию пустой
                 брать только строку из языка # -->
            <xs:element name="title" type="xs:string" minOccurs="0" />
        </xs:sequence>
        <!-- m_origin по умолчанию eSource -->
        <xs:attribute name="org" type="tns:FormElementOrigin"/>
        <!-- m_openingMode по умолчанию Normal -->
        <xs:attribute name="openingMode" type="tns:FormWindowOpeningMode"/>
        <!-- m_width по умолчанию 0 -->
        <xs:attribute name="width" type="xs:decimal"/>
        <!-- m_height по умолчанию 0 -->
        <xs:attribute name="height" type="xs:decimal"/>
        <!-- m_enterKeyBehavior по умолчанию ControlNavigation -->
        <xs:attribute name="enterKeyBehavior" type="tns:FormEnterKeyBehavior"/>
        <!-- m_saveFormDataInSettings по умолчанию DontUse -->
        <xs:attribute name="saveFormDataInSettings" type="tns:SaveFormDataInSettings" />
        <!-- m_saveFormDataInSettings по умолчанию DontUse -->
        <xs:attribute name="autoSaveFormDataInSettings" type="tns:AutoSaveFormDataInSettings" />
        <!-- m_autoTitle по умолчанию true -->
        <xs:attribute name="autoTitle" type="xs:boolean"/>
        <!-- m_grouping по умолчанию Vertical -->
        <xs:attribute name="grouping" type="tns:FormChildrenGroup" />
        <!-- m_childrenWidth по умолчанию Auto -->
        <xs:attribute name="childrenWidth" type="tns:FormChildrenWidth" />
        <!-- m_autoFillCheck по умолчанию true -->
        <xs:attribute name="autoFillCheck" type="xs:boolean"/>
        <!-- m_customizable по умолчанию true -->
        <xs:attribute name="customizable" type="xs:boolean"/>
        <!-- m_enabled по умолчанию true -->
        <xs:attribute name="enabled" type="xs:boolean"/>
        <!-- m_readOnly по умолчанию false -->
        <xs:attribute name="readOnly" type="xs:boolean"/>
        <!-- m_commandBarLocation по умолчанию Auto -->
        <xs:attribute name="commandBarLocation" type="tns:FormElementCommandBarLocation" />
        <!-- m_purposeUseKey по умолчанию пустой -->
        <xs:attribute name="purposeUseKey" type="xs:string"/>
        <!-- m_windowOptionsKey по умолчанию пустой -->
        <xs:attribute name="windowOptionsKey" type="xs:string"/>
    </xs:complexType>

    <xs:complexType name="Form">
        <xs:sequence>
            <!-- m_pElements -->
            <xs:element name="elements" type="tns:MainElement"/>
            <!-- m_pCommands если не пустые -->
            <xs:element name="command" type="tns:Command" minOccurs="0" maxOccurs="unbounded" />
            <!-- m_pProperties если не пустые -->
