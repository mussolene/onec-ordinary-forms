<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" 
           xmlns:tns="http://v8.1c.ru/8.2/mngsrv/ws"
           xmlns:core="http://v8.1c.ru/8.1/data/core" 
           xmlns:ui="http://v8.1c.ru/8.1/data/ui"
           xmlns:ent="http://v8.1c.ru/8.1/data/enterprise"
           xmlns:uobj="http://v8.1c.ru/8.2/uobjects"
           xmlns:dcss="http://v8.1c.ru/8.1/data-composition-system/settings"
           xmlns:dcsdt="http://v8.1c.ru/8.1/data-composition-system/details"
           xmlns:dcscore="http://v8.1c.ru/8.1/data-composition-system/core"
           xmlns:cmi="http://v8.1c.ru/8.2/managed-application/cmi"
           xmlns:dl="http://v8.1c.ru/8.2/managed-application/dynamic-list"
           xmlns:lfl="http://v8.1c.ru/8.2/managed-application/logform/layouter"
           xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform"
           xmlns:ma="http://v8.1c.ru/8.2/managed-application/core"
           xmlns:module="http://v8.1c.ru/8.2/managed-application/modules"
           xmlns:sheet="http://v8.1c.ru/8.2/data/spreadsheet"
           xmlns:bsl="http://v8.1c.ru/8.2/data/bsl"
           targetNamespace="http://v8.1c.ru/8.2/mngsrv/ws"
           elementFormDefault="qualified" 
           attributeFormDefault="unqualified" 
           version="1.0">
    <xs:import namespace="http://v8.1c.ru/8.1/data/core" schemaLocation="../../../xdto/src/res/core.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/ui" schemaLocation="../../../xdto/src/res/uiobjects.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data/enterprise" schemaLocation="../../../enums/src/res/enums.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data-composition-system/settings" schemaLocation="../../../dcscore/src/res/settings.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data-composition-system/details" schemaLocation="../../../dcscore/src/res/details.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data-composition-system/core" schemaLocation="../../../dcscore/src/res/core.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/uobjects" schemaLocation="uobjects.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/cmi" schemaLocation="cmi.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/dynamic-list" schemaLocation="dlist.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/logform/layouter" schemaLocation="logformlay.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/logform" schemaLocation="logform.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/managed-application/modules" schemaLocation="modules.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/spreadsheet" schemaLocation="../../../moxel/src/res/spreadsheetDocument.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.2/data/bsl" schemaLocation="../../../bsl/src/res/bsl.xsd"/>

    <xs:element name="request"/>
    <xs:element name="response"/>

    <xs:complexType name="BSLModuleId">
        <xs:sequence>
            <xs:element name="URL" type="xs:string" />
            <xs:element name="UUID" type="core:UUID" />
            <xs:element name="PropertyId" type="core:UUID" />
            <xs:element name="ExtId" type="xs:decimal" default="0" />
            <xs:element name="Version" type="core:UUID"  />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ModuleInfo">
        <xs:sequence>
            <xs:element name="ID" type="tns:BSLModuleId" />
            <xs:element name="Name" type="xs:string" minOccurs="0" />
            <xs:element name="FullName" type="xs:string" minOccurs="0" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="ModuleMethodDefsAnswer">
        <xs:sequence>
            <xs:element name="Method" type="module:MethodDef" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="CallParam">
        <xs:sequence>
            <xs:element name="DefValue" type="xs:boolean" />
            <xs:element name="Value" type="xs:string" minOccurs="0" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="CallCommonModuleMethodQuery">
        <xs:sequence>
            <xs:element name="ModuleId" type="tns:BSLModuleId" />
            <xs:element name="Name" type="xs:string" />
            <xs:element name="Param" type="tns:CallParam" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="CallCommonModuleMethodAnswer">
        <xs:sequence>
            <xs:element name="RetValue" type="xs:string" minOccurs="0" />
            <xs:element name="Param" type="xs:string" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>

  <!-- Область командного интерфейса -->
  <xs:simpleType name="CommandInterfaceArea">
    <xs:restriction base="xs:string">
      <xs:enumeration value="topLevel" />
      <xs:enumeration value="actions" />
      <xs:enumeration value="subsystem" />
    </xs:restriction>
  </xs:simpleType>

  <!-- Параметры запроса на сохранение пользовательских настроек -->
  <xs:complexType name="CMISaveCustomizationParam">
    <xs:sequence>
      <xs:element name="fragmentId" type="core:UUID" />
      <xs:element name="category" type="cmi:GroupCategory" />
      <xs:element name="area" type="tns:CommandInterfaceArea" />
      <xs:element name="settings" type="cmi:CommandInterfaceItems" />
    </xs:sequence>
  </xs:complexType>

  <!-- Параметры запроса на сохранение пользовательских настроек -->
  <xs:complexType name="CMILoadCustomizationParam">
    <xs:sequence>
      <xs:element name="fragmentId" type="core:UUID" />
      <xs:element name="category" type="cmi:GroupCategory" />
      <xs:element name="area" type="tns:CommandInterfaceArea" />
      <xs:element name="desktop" type="xs:boolean"  minOccurs="0"/>
      <xs:element name="defaultData" type="cmi:CommandInterfaceItems" />
      <xs:element name="customData" type="cmi:CommandInterfaceItems" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="GetAddDataTreeAnswer">
        <xs:sequence>
            <xs:element name="abc" type="xs:boolean" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="GetAddDataValueAnswer">
        <xs:sequence>
            <xs:element name="abc" type="xs:boolean" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="PictureQueryAnswer">
        <xs:sequence>
            <xs:element name="Item" type="xs:string" />
        </xs:sequence>
    </xs:complexType>
    <!-- 
    Типы для получения представлений ссылок
    -->
    <!-- Представление ссылки конкретного типа -->
    <xs:complexType name="RefPresentation">
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute name="id" type="core:UUID" />
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <!-- Коллекция представлений ссылок конкретного типа -->
    <xs:complexType name="RefPresentationList">
        <xs:sequence>
            <xs:element name="ref" type="tns:RefPresentation" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
        <xs:attribute name="typeId" type="core:UUID" />
    </xs:complexType>
    <!-- Коллекция представлений ссылок различных типов -->
    <xs:complexType name="RefPresentationMap">
        <xs:sequence>
            <xs:element name="item" type="tns:RefPresentationList" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>
    <!-- Представление ссылки конкретного типа таблицы внешнего источника данных-->
    <xs:complexType name="EDBRefPresentation">
        <xs:sequence>
            <xs:element name="value" type="xs:anyType" minOccurs="1" maxOccurs="1" />
            <xs:element name="pres" type="xs:string" minOccurs="0" maxOccurs="1" />
        </xs:sequence>
    </xs:complexType>
    <!-- Коллекция представлений ссылок конкретного типа таблицы внешнего источника данных -->
    <xs:complexType name="EDBRefPresentationList">
        <xs:sequence>
            <xs:element name="ref" type="tns:EDBRefPresentation" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
        <xs:attribute name="typeId" type="core:UUID" />
    </xs:complexType>
    <!-- Коллекция представлений ссылок таблиц внешних источников данных -->
    <xs:complexType name="EDBRefPresentationMap">
        <xs:sequence>
            <xs:element name="item" type="tns:EDBRefPresentationList" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="OperationRefs">
        <xs:sequence>
            <xs:element name="refs" type="tns:RefPresentationMap" minOccurs="0"/>
            <xs:element name="edbRefs" type="tns:EDBRefPresentationMap" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    
    <!-- 
    Типы для получения данных через точку
    -->
    <xs:complexType name="ThroughRefPathItem">
        <xs:sequence>
            <xs:element name="path" type="xs:string" minOccurs="0"/>
            <xs:element name="type" type="core:UUID" minOccurs="0"/>
            <xs:element name="ref" type="core:UUID" minOccurs="0"/>
            <xs:element name="edbRef" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ThroughRefPaths">
        <xs:sequence>
            <xs:element name="item" type="tns:ThroughRefPathItem" minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>

  <xs:complexType name="ThroughRefsDataItem">
    <xs:sequence>
      <xs:element name="value"/>
      <xs:element name="fail" type="xs:boolean" minOccurs="0"/>
      <xs:element name="types" type="core:UUID" minOccurs="0" maxOccurs="unbounded" />
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="ThroughRefsData">
        <xs:sequence>
            <xs:element name="item" type="tns:ThroughRefsDataItem"  minOccurs="0" maxOccurs="unbounded" />
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ThroughRefsAnswer">
        <xs:sequence>
            <xs:element name="data" type="tns:ThroughRefsData" />
            <xs:element name="refs" type="tns:RefPresentationMap" minOccurs="0"/>
            <xs:element name="edbRefs" type="tns:EDBRefPresentationMap" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    
    <xs:complexType name="QuickChoiceForTypeQuery">
        <xs:attribute name="type" type="core:UUID" />
    </xs:complexType>

    <xs:simpleType name="QuickChoiceModeForType">
        <xs:restriction base="xs:string">
            <xs:enumeration value="SoftFromForm" />
            <xs:enumeration value="SoftInList" />
            <xs:enumeration value="HardFromForm" />
            <xs:enumeration value="HardInList" />
        </xs:restriction>
    </xs:simpleType>

    <xs:complexType name="QuickChoiceForAnswer">
        <xs:attribute name="mode" type="tns:QuickChoiceModeForType" />
    </xs:complexType>

    <xs:complexType name="SearchOnInputForbiddenAnswer">
      <xs:attribute name="mode" type="xs:boolean" />
    </xs:complexType>

    <xs:complexType name="LogFormStructure">
        <xs:sequence>
            <xs:element name="descriptions" type="uobj:FormDataDescriptions"/>
            <xs:element name="type" type="xs:string"/>
            <xs:element name="data" type="uobj:Structure"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="LogFormClearUserSettingsParam">
        <xs:sequence>
            <xs:element name="rKey" type="xs:string" minOccurs="0"/>
            <xs:element name="id" type="xs:string" minOccurs="0"/>
            <xs:element name="fid" type="core:UUID" minOccurs="0"/>
            <xs:element name="props" type="uobj:Changes"/>
            <xs:element name="trd" type="tns:LogFormStructure" minOccurs="0"/>
            <xs:element name="tri" type="tns:TRPropertyList" minOccurs="0"/>
            <xs:element name="dd" type="tns:DynamicData" minOccurs="0"/>
            <xs:element name="me" type="lf:MainElement" minOccurs="0"/>
            <xs:element name="lfl" type="lfl:Form" minOccurs="0"/>
            <xs:element name="mw" type="xs:decimal" minOccurs="0"/>
            <xs:element name="mh" type="xs:decimal" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormQueryTRPropertiesParam">
        <xs:sequence>
            <xs:element name="rKey" type="xs:string" minOccurs="0"/>
            <xs:element name="id" type="xs:string" minOccurs="0"/>
            <xs:element name="props" type="uobj:Changes"/>
            <xs:element name="me" type="lf:MainElement" minOccurs="0"/>
            <xs:element name="en" type="xs:string" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormFieldInfo">
        <xs:sequence>
            <xs:element name="fldId" type="core:CompositeID" minOccurs="0"/>
            <xs:element name="code" type="xs:string" minOccurs="0"/>
            <xs:element name="descr" type="xs:string" minOccurs="0"/>
            <xs:element name="tdp" type="core:TypeDescription" minOccurs="0"/>
            <xs:element name="defKind" type="xs:decimal" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormTRPropertiesInfos">
        <xs:sequence>
            <xs:sequence>
                <xs:element name="item" type="tns:LogFormFieldInfo" minOccurs="0" maxOccurs="unbounded" />
            </xs:sequence>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormElementsPresentationParam">
        <xs:sequence>
            <xs:element name="rKey" type="xs:string" minOccurs="0"/>
            <xs:element name="id" type="xs:string" minOccurs="0"/>
            <xs:element name="fid" type="core:UUID" minOccurs="0"/>
            <xs:element name="props" type="uobj:Changes"/>
            <xs:element name="applUsr" type="xs:boolean"  minOccurs="0"/>
            <xs:element name="navigator" type="xs:boolean"  minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormElementPresentationItem">
        <xs:sequence>
            <xs:element name="name" type="xs:string"  minOccurs="0"/>
            <xs:element name="present" type="xs:string"  minOccurs="0"/>
            <xs:element name="important" type="xs:boolean"  minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormElementsPresentation">
        <xs:sequence>
          <xs:element name="me" type="lf:MainElement" minOccurs="0"/>
          <xs:sequence>
                <xs:element name="item" type="tns:LogFormElementPresentationItem" minOccurs="0" maxOccurs="unbounded" />
            </xs:sequence>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="LogFormElementSettingsParam">
        <xs:sequence>
            <xs:element name="id" type="xs:string" minOccurs="0"/>
            <xs:element name="en" type="xs:string" minOccurs="0"/>
            <xs:element name="sn" type="xs:string" minOccurs="0"/>
            <xs:element name="sv" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="DynamicListFindItem">
        <xs:sequence>
            <xs:element name="value" minOccurs="0"/>
        </xs:sequence>
        <xs:attribute name="descr" type="xs:string"/>
    </xs:complexType>

    <xs:complexType name="DynamicListFindItems">
        <xs:sequence>
            <xs:element name="item" type="tns:DynamicListFindItem" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="DynamicListDSParam">
        <xs:annotation>
            <xs:documentation>Запрос данных в динамическом списке</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="list" type="dl:DynamicList" minOccurs="0"/>
            <xs:element name="dataPath" type="dl:LFEDataPath" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="current" minOccurs="0"/>
            <xs:element name="filter" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="parent" minOccurs="0"/>
            <xs:element name="period" type="core:StandardPeriod" minOccurs="0"/>
            <xs:element name="fieldName" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="findPattern" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="checkSL" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="checkON" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="checkC" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkCP" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkTP" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkFV" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkLV" minOccurs="0" maxOccurs="1"/>
        </xs:sequence>
        <xs:attribute name="cacheID" type="core:UUID"/>
        <xs:attribute name="remoteKey" type="xs:string"/>
        <xs:attribute name="tableId" type="xs:decimal"/>
        <xs:attribute name="formUUID" type="core:UUID"/>
        <xs:attribute name="refresh" type="xs:boolean"/>
        <xs:attribute name="forward" type="xs:boolean"/>
        <xs:attribute name="backward" type="xs:boolean"/>
        <xs:attribute name="autopos" type="xs:boolean"/>
        <xs:attribute name="page" type="xs:decimal"/>
        <xs:attribute name="includeCurrent" type="xs:boolean"/>
        <xs:attribute name="source" type="xs:decimal"/>
        <xs:attribute name="showTree" type="xs:boolean"/>
        <xs:attribute name="autoParent" type="xs:boolean"/>
        <xs:attribute name="level" type="xs:decimal"/>
        <xs:attribute name="autoLevel" type="xs:boolean"/>
        <xs:attribute name="presents" type="xs:boolean"/>
        <xs:attribute name="findType" type="xs:decimal"/>
        <xs:attribute name="needDataDescr" type="xs:boolean"/>
        <xs:attribute name="choiceMode" type="xs:boolean"/>
        <xs:attribute name="cacheableFormId" type="core:UUID"/>
    </xs:complexType>

    <xs:complexType name="DynamicListCellAppearance">
      <xs:annotation>
        <xs:documentation>Оформление ячейки строки динамического списка</xs:documentation>
      </xs:annotation>
      <xs:sequence>
        <xs:element name="tc" type="ui:Color" minOccurs="0"/>
        <xs:element name="bc" type="ui:Color" minOccurs="0"/>
        <xs:element name="ha" type="ui:HorizontalAlign" minOccurs="0"/>
        <xs:element name="tf" type="ui:Font" minOccurs="0"/>
        <xs:element name="vf" type="xs:string" minOccurs="0"/>
        <xs:element name="vt" type="xs:string" minOccurs="0"/>
        <xs:element name="fv" type="xs:string" minOccurs="0"/>
        <xs:element name="fe" type="xs:string" minOccurs="0"/>
        <xs:element name="fs" type="xs:string" minOccurs="0"/>
      </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FieldUsage">
      <xs:annotation>
        <xs:documentation>Использование полей в зависимости от типа строки</xs:documentation>
      </xs:annotation>
      <xs:attribute name="n" type="xs:string"/>
      <xs:attribute name="u" type="xs:decimal"/>
    </xs:complexType>

    <xs:complexType name="AnswerDataPart">
        <xs:annotation>
            <xs:documentation>Ответ динамического списка</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="fu" type="tns:FieldUsage" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="dataName" type="xs:string" minOccurs="0" maxOccurs="1"/>
            <xs:element name="dataDescr" type="uobj:FormDataDescriptions" minOccurs="0" maxOccurs="1"/>
            <xs:element name="rowsParent" minOccurs="0" maxOccurs="1"/>
            <xs:element name="rows" type="uobj:Structure" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="fif" type="xs:boolean"/>
        <xs:attribute name="lil" type="xs:boolean"/>
        <xs:attribute name="key" type="xs:string"/>
        <xs:attribute name="folder" type="xs:string"/>
        <xs:attribute name="parent" type="xs:string"/>
        <xs:attribute name="period" type="xs:string"/>
        <xs:attribute name="posted" type="xs:string"/>
        <xs:attribute name="image" type="xs:string"/>
        <xs:attribute name="marked" type="xs:string"/>
        <xs:attribute name="owner" type="xs:string"/>
        <xs:attribute name="registrator" type="xs:string"/>
    </xs:complexType>

    <xs:complexType name="OpenedNodes">
        <xs:sequence>
            <xs:element name="opened" type="tns:AnswerDataPart" minOccurs="0" maxOccurs="unbounded"/>
        </xs:sequence>
        <xs:attribute name="level" type="xs:decimal"/>
    </xs:complexType>

    <xs:complexType name="DynamicListDSAnswer">
        <xs:annotation>
            <xs:documentation>Ответ динамического списка</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="forward" type="tns:AnswerDataPart" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="backward" type="tns:AnswerDataPart" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="opened" type="tns:OpenedNodes" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="picture" type="ui:Picture" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="disGroup" type="xs:string" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="refs" type="tns:RefPresentationMap" minOccurs="0"/>
            <xs:element name="edbRefs" type="tns:EDBRefPresentationMap" minOccurs="0"/>
            <xs:element name="cas" type="tns:DynamicListCellAppearance" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="checkSL" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="checkON" minOccurs="0" maxOccurs="unbounded"/>
            <xs:element name="checkC" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkCP" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkTP" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkFV" minOccurs="0" maxOccurs="1"/>
            <xs:element name="checkLV" minOccurs="0" maxOccurs="1"/>
            <xs:element name="ccd" minOccurs="0"/>
        </xs:sequence>
        <xs:attribute name="cacheID" type="core:UUID"/>
        <xs:attribute name="level" type="xs:decimal"/>
        <xs:attribute name="hierarhy" type="xs:boolean"/>
        <xs:attribute name="notFound" type="xs:boolean"/>
        <xs:attribute name="errorFound" type="xs:boolean"/>
        <xs:attribute name="staticQuery" type="xs:boolean"/>
        <xs:attribute name="useSingleDescr" type="xs:boolean"/>
    </xs:complexType>
    <xs:complexType name="DynamicListDSDeleteParam">
        <xs:annotation>
            <xs:documentation>Запрос удаления элемента динамического списка</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="form" type="core:UUID"/>
            <xs:element name="table" type="core:UUID" />
            <xs:element name="current" minOccurs="0" maxOccurs="unbounded" />
            <xs:element name="mark" type="xs:boolean" />
