<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:tns="http://v8.1c.ru/8.1/data-composition-system/settings"
           xmlns:core="http://v8.1c.ru/8.1/data/core"
           xmlns:dcscore="http://v8.1c.ru/8.1/data-composition-system/core"
           targetNamespace="http://v8.1c.ru/8.1/data-composition-system/settings"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified">
	<xs:import namespace="http://v8.1c.ru/8.1/data/core" schemaLocation="../../../xdto/src/res/core.xsd"/>
    <xs:import namespace="http://v8.1c.ru/8.1/data-composition-system/core" schemaLocation="core.xsd"/>
    <xs:element name="settings" type="tns:Settings">
		<xs:annotation>
			<xs:documentation>Корневые настройки</xs:documentation>
		</xs:annotation>
	</xs:element>
	<xs:complexType name="Settings">
		<xs:annotation>
			<xs:documentation>Настройки</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="userFields" type="tns:UserFields" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Пользовательские поля.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="selection" type="tns:Selection" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Выбранные поля. При выводе отчета не используется</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="filter" type="tns:Filter" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Глобальный фильтр. Прописывается как условия в запросы наборов данных и как фильтры для наборов данных целиком.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="dataParameters" type="tns:DataParameterValues" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Значение парметров получения данных.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="order" type="tns:Order" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Порядок. Прописывается как упорядочивание в запросы набоов данных.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="conditionalAppearance" type="tns:ConditionalAppearance" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Условное оформление. Используется во всей компоновке.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="outputParameters" type="tns:CompositionOutputParameterValues" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Параметры вывода. Использование зависит от свойства.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="item" type="tns:StructureItem" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Элемент структуры отчета</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="additionalProperties" type="core:Structure" minOccurs="0" maxOccurs="1">
				<xs:annotation>
					<xs:documentation>Дополнительные свойства</xs:documentation>
				</xs:annotation>
			</xs:element>
            <xs:element name="itemsViewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Режим отображения структуры</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="itemsUserSettingID" type="xs:string" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификатор выделенной настройки структуры</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="itemsUserSettingPresentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Представление выделенной настройки структуры</xs:documentation>
				</xs:annotation>
			</xs:element>
        </xs:sequence>
    </xs:complexType>
	<xs:complexType name="DataParameterValues">
		<xs:annotation>
			<xs:documentation>Параметры получения данных</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="dcscore:ParameterValues"/>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="CompositionOutputParameterValues">
		<xs:annotation>
			<xs:documentation>
                Параметры вывода всей компоновки. Возможны следующие параметры:
                TotalsPlacement - итоги по строкам колонкам (TotalPlacement)
                GroupFieldsPlacement - размещение полей группировки (GroupFieldsPlacementType)
                GroupPlacement - тип размещения группировок (GroupPlacementType)
                AttributePlacement
                ResourcePlacement
                HorizontalOverallPlacement - (TotalPlacement)
                VerticalOverallPlacement - (TotalPlacement)
                ChartType (ТипДиаграммы) - тип диаграммы. Перечисление ТипДиаграммы.
                ChartType.BaseValue (ТипДиаграммы.БазовоеЗначение)– Базовое значение. Число.
                ChartType.HideBaseValue (ТипДиаграммы.ПропускатьБазовоеЗначение) - Пропускать точки с базовым значением. Булево.
                ChartType.LabelType (ТипДиаграммы.ВидПодписей) - Состав подписей. Перечисление ВидПодписейКДиаграмме (ChartLabelType).
                ChartType.AutoSeriesSeparation (ТипДиаграммы.АвтоРаздвижениеСерий) Режим раздвижения. Перечисление АвтоРаздвижениеСерий (AutoSeriesSeparation).
                ChartType.ShowDataTable (ТипДиаграммы.ОтображатьТаблицуДанных)- Отображать таблицу данных. Булево.
                ChartType.MaxValue (ТипДиаграммы.МаксимальноеЗначение) - Максимальное значение. Число.
                ChartType.MinValue (ТипДиаграммы.МинимальноеЗначение) - Минимальное значение. Число.
                ChartType.Outline (ТипДиаграммы.Окантовка) – Окантовка. Булево.
                ChartType.Gradient (ТипДиаграммы.Градиент) – Градиент. Булево.
                ChartType.Font(ТипДиаграммы.Шрифт) - Шрифт диаграммы. Шрифт
                ChartType.BackColor(ТипДиаграммы.ЦветФона) - Цвет фона диаграммы. Цвет.
                ChartType.BorderStyle(ТипДиаграммы.СтильЛинии) - стиль линии вокруг диаграммы. Линия.
                ChartType.LegendPlacement(ТипДиаграммы.РасположениеЛегенды) - расположение легенды в диаграммы. РасположениеЛегендыДиаграммыСистемыКомпоновкиДанных.
                ChartType.GaugeChartQualityBands(ТипДиаграммы.ПолосыИзмерительнойДиаграммы) - полосы для измерительной диаграммы. ПолосыИзмерительнойДиаграммы.
                ChartType.ResourcesPlacement(ТипДиаграммы.РасположениеРесурсов) - расположение ресурсов в диаграмме. РасположениеРесурсовВДиаграммеКомпоновкиДанных.

                FieldsTitleType - тип заголовков полей(DataCompositionFieldsTitleType)
                OutputTitle - выводить заголовок (DataCompositionTextOutputType)
                Title - заголовок (Строка)
                OutputDataParameters - выводить параметры данных (DataCompositionTextOutputType)
                OutputFilter - выводить отбор (DataCompositionTextOutputType)
                ResourcesAutoPosition - авто позиция ресурсов (DataCompositionResourcesAutoPosition)
            </xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="dcscore:ParameterValues"/>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="Order">
		<xs:annotation>
			<xs:documentation>Порядок</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="item" type="tns:OrderItem" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Элемент порядка</xs:documentation>
				</xs:annotation>
			</xs:element>
            <xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Режим отображения</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="userSettingID" type="xs:string" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификатор выделенной настройки</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="userSettingPresentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Представление выделенной настройки</xs:documentation>
				</xs:annotation>
			</xs:element>
        </xs:sequence>
	</xs:complexType>
	<xs:complexType name="OrderItem" abstract="true">
		<xs:annotation>
			<xs:documentation>Элемент порядка</xs:documentation>
		</xs:annotation>
	</xs:complexType>
	<xs:complexType name="OrderItemField">
        <xs:annotation>
            <xs:documentation>Элемент порядка поле</xs:documentation>
        </xs:annotation>
        <xs:complexContent>
            <xs:extension base="tns:OrderItem">
                <xs:sequence>
					<xs:element name="use" type="xs:boolean"
						minOccurs="0">
						<xs:annotation>
							<xs:documentation>
								Элемент порядка используется.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="field" type="dcscore:Field">
						<xs:annotation>
							<xs:documentation>
								Поле упорядочивания.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="orderType"
						type="dcscore:DataCompositionSortDirection" minOccurs="0">
						<xs:annotation>
							<xs:documentation>
								Тип упорядочивания.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
		            <xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
		                <xs:annotation>
		                    <xs:documentation>Режим отображения</xs:documentation>
		                </xs:annotation>
		            </xs:element>
				</xs:sequence>
                <xs:attribute name="iID" type="xs:decimal" default="0" use="optional"/>
            </xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="OrderItemAuto">
		<xs:annotation>
			<xs:documentation>Элемент порядка авто</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="tns:OrderItem">
				<xs:sequence>
					<xs:element name="use" type="xs:boolean"
						minOccurs="0">
						<xs:annotation>
							<xs:documentation>
								Элемент порядка используется.
							</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
                <xs:attribute name="iID" type="xs:decimal" default="0" use="optional"/>
            </xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:complexType name="Filter">
		<xs:annotation>
			<xs:documentation>Отбор</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="item" type="tns:FilterItem" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Элемент отбора</xs:documentation>
				</xs:annotation>
			</xs:element>
            <xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Режим отображения</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="userSettingID" type="xs:string" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификатор выделенной настройки</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="userSettingPresentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Представление выделенной настройки</xs:documentation>
				</xs:annotation>
			</xs:element>
        </xs:sequence>
	</xs:complexType>
	<xs:complexType name="FilterItem" abstract="true">
		<xs:annotation>
			<xs:documentation>Элемент отбора</xs:documentation>
		</xs:annotation>
	</xs:complexType>
	<xs:complexType name="FilterItemComparison">
		<xs:annotation>
			<xs:documentation>Элемент отбора - сравнение</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="tns:FilterItem">
				<xs:sequence>
					<xs:element name="use" type="xs:boolean" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Элемент отбора используется.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="left" type="xs:anyType" maxOccurs="1" minOccurs="0" nillable="true">
						<xs:annotation>
							<xs:documentation>Значение в левой части условия. Может содержать константное значение или значение - поле.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="comparisonType" type="tns:DataCompositionComparisonType">
						<xs:annotation>
							<xs:documentation>Тип сравнения.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="right" type="xs:anyType" minOccurs="0" maxOccurs="unbounded" nillable="true">
						<xs:annotation>
							<xs:documentation>Значение в правой части условия. Может содержать константное значение или значение - поле.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="presentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Представление элемента</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="application" type="tns:DataCompositionFilterApplicationType" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Применение элемента</xs:documentation>
						</xs:annotation>
					</xs:element>		
					<xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Режим отображения</xs:documentation>
						</xs:annotation>
					</xs:element>		
					<xs:element name="userSettingID" type="xs:string" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Идентификатор выделенной настройки</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="userSettingPresentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Представление выделенной настройки</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
                <xs:attribute name="iID" type="xs:decimal" default="0" use="optional"/>
            </xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="DataCompositionComparisonType">
		<xs:annotation>
			<xs:documentation>Вид сравнения</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="Equal"/>
			<xs:enumeration value="NotEqual" />
			<xs:enumeration value="Less"/>
			<xs:enumeration value="LessOrEqual"/>
			<xs:enumeration value="Greater"/>
			<xs:enumeration value="GreaterOrEqual"/>
			<xs:enumeration value="Contains"/>
			<xs:enumeration value="InList"/>
			<xs:enumeration value="InListByHierarchy"/>
			<xs:enumeration value="InHierarchy" />
			<xs:enumeration value="NotContains"/>
			<xs:enumeration value="NotInList"/>
			<xs:enumeration value="NotInListByHierarchy"/>
			<xs:enumeration value="NotInHierarchy" />
			<xs:enumeration value="Filled"/>
			<xs:enumeration value="NotFilled" />
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="FilterItemGroup">
		<xs:annotation>
			<xs:documentation>Элемент отбора группа</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="tns:FilterItem">
				<xs:sequence>
					<xs:element name="use" type="xs:boolean" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Элемент отбора используется.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="groupType" type="tns:DataCompositionFilterItemsGroupType">
						<xs:annotation>
							<xs:documentation>Тип группы</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="item" type="tns:FilterItem" minOccurs="0" maxOccurs="unbounded">
						<xs:annotation>
							<xs:documentation>Вложенные элементы отбора.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="presentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Представление элемента</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="application" type="tns:DataCompositionFilterApplicationType" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Применение элемента</xs:documentation>
						</xs:annotation>
					</xs:element>		
					<xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Режим отображения</xs:documentation>
						</xs:annotation>
					</xs:element>		
					<xs:element name="userSettingID" type="xs:string" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Идентификатор выделенной настройки</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="userSettingPresentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Представление выделенной настройки</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
                <xs:attribute name="iID" type="xs:decimal" default="0" use="optional"/>
            </xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="DataCompositionFilterItemsGroupType">
		<xs:annotation>
			<xs:documentation>Тип группы отбора</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="AndGroup"/>
			<xs:enumeration value="OrGroup"/>
			<xs:enumeration value="NotGroup"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="Selection">
		<xs:annotation>
			<xs:documentation>Выбранные элементы</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="item" type="tns:SelectedItem" minOccurs="0" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Элемент выбора.</xs:documentation>
				</xs:annotation>
			</xs:element>
            <xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Режим отображения</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="userSettingID" type="xs:string" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Идентификатор выделенной настройки</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="userSettingPresentation" type="xs:anyType" maxOccurs="1" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Представление выделенной настройки</xs:documentation>
				</xs:annotation>
			</xs:element>
        </xs:sequence>
	</xs:complexType>
	<xs:complexType name="SelectedItem" abstract="true">
		<xs:annotation>
			<xs:documentation>Выбранный элемент</xs:documentation>
		</xs:annotation>
	</xs:complexType>
	<xs:complexType name="SelectedItemField">
		<xs:annotation>
			<xs:documentation>Выбранное поле</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="tns:SelectedItem">
				<xs:sequence>
					<xs:element name="use" type="xs:boolean" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Поле используется</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="field" type="dcscore:Field">
						<xs:annotation>
							<xs:documentation>Путь к данным поля.</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="title" type="xs:string" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Заголовок</xs:documentation>
						</xs:annotation>
					</xs:element>
					<xs:element name="lwsTitle" type="core:LocalStringType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Заголовок на нескольких языках.</xs:documentation>
						</xs:annotation>
					</xs:element>
		            <xs:element name="viewMode" type="tns:DataCompositionSettingsItemViewMode" maxOccurs="1" minOccurs="0">
		                <xs:annotation>
		                    <xs:documentation>Режим отображения</xs:documentation>
		                </xs:annotation>
		            </xs:element>
				</xs:sequence>
                <xs:attribute name="iID" type="xs:decimal" default="0" use="optional"/>
            </xs:extension>
		</xs:complexContent>
	</xs:complexType>
	<xs:simpleType name="DataCompositionFieldPlacement">
		<xs:annotation>
			<xs:documentation>Тип размещения поля</xs:documentation>
		</xs:annotation>
		<xs:restriction base="xs:string">
			<xs:enumeration value="Auto"/>
			<xs:enumeration value="Horizontally"/>
			<xs:enumeration value="Vertically"/>
			<xs:enumeration value="SpecialColumn"/>
			<xs:enumeration value="Together"/>
		</xs:restriction>
	</xs:simpleType>
	<xs:complexType name="SelectedItemFolder">
		<xs:annotation>
			<xs:documentation>Выбранная папка</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
